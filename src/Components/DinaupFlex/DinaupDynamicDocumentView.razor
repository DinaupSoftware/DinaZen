@namespace DinaZen.Components.DinaupFlex

@if (_isLoading)
{
	<Loader />
}
else if (_requiresVariables && _docInfo != null)
{
	<div class="dnz-doc-view">
		<div class="dnz-doc-header">
			<RadzenIcon Icon="description" Style="font-size:18px" />
			<span>Variables requeridas</span>
		</div>
		<div class="dnz-doc-body" style="padding:16px">
			@if (VariablesTemplate != null && _docMetadata != null)
			{
				@VariablesTemplate(new DinaupVariablesContext
				{
					Document = _docMetadata,
					VariableValues = VariableValues,
					OnConfirm = EventCallback.Factory.Create<Dictionary<string, string>>(this, HandleVariableConfirm)
				})
			}
			else
			{
				@* Fallback basico para variables sin template custom *@
				<RadzenCard>
					<RadzenStack Gap="1rem">
						<RadzenText TextStyle="TextStyle.Subtitle1">Se requieren variables para generar este documento</RadzenText>
						@if (_docInfo?.Questions?.Variables != null)
						{
							@foreach (var variable in _docInfo.Questions.Variables.Values)
							{
								<div>
									<RadzenLabel Text="@variable.Label" />
									<RadzenTextBox Style="width:100%"
												   Change="@(value => { VariableValues ??= new(); VariableValues[variable.KeyWord] = value; })" />
								</div>
							}
						}
						<RadzenButton Text="Aceptar" Icon="check" ButtonStyle="ButtonStyle.Primary"
									  Click="@(() => HandleVariableConfirm(VariableValues ?? new()))" />
					</RadzenStack>
				</RadzenCard>
			}
		</div>
	</div>
}
else if (_documentContent.IsNotEmpty())
{
	<div class="dnz-doc-view">
		<div class="dnz-doc-header">
			<RadzenIcon Icon="description" Style="font-size:18px" />
			<span>@(_docInfo?.Name ?? "Documento")</span>

			<div class="d-flex align-items-center gap-2 ms-auto">
				@if (CompatibleDocuments != null && CompatibleDocuments.Any())
				{
					<RadzenDropDown AllowFiltering="true"
								   FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
								   FilterOperator="StringFilterOperator.Contains"
								   @bind-Value="@DocId"
								   @bind-Value:after="@UpdateAsync"
								   TValue="string"
								   ValueProperty="@nameof(DinaupDynamicDocumentDTO.IDSTR)"
								   TextProperty="@nameof(DinaupDynamicDocumentDTO.Title)"
								   Data="@CompatibleDocuments"
								   Style="max-width:300px" />
				}
				<RadzenButton Text="Imprimir" Icon="print" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
							  Click="@PrintDocument" />
				@if (OnSendEmail.HasDelegate)
				{
					<RadzenButton Text="Enviar por email" Icon="send" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
								  Click="@HandleSendEmail" />
				}
			</div>
		</div>

		<div class="dnz-doc-body">
			<iframe id="@_iframeId" style="width:100%; height:100%; border:none; border-radius:6px" />
		</div>
	</div>
}
else if (_errorMessage.IsNotEmpty())
{
	<RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">
		@_errorMessage
	</RadzenAlert>
}

@code {

	/// <summary>
	/// Cliente DinaupSL.
	/// </summary>
	[Parameter, EditorRequired] public DinaupClientC Client { get; set; }

	/// <summary>
	/// ID del documento dinamico.
	/// </summary>
	[Parameter, EditorRequired] public string DocId { get; set; } = "";

	/// <summary>
	/// Variables para la ejecucion del documento.
	/// </summary>
	[Parameter] public Dictionary<string, string> VariableValues { get; set; } = new();

	/// <summary>
	/// Lista de documentos compatibles (para selector dropdown).
	/// </summary>
	[Parameter] public List<DinaupDynamicDocumentDTO> CompatibleDocuments { get; set; }

	/// <summary>
	/// Si true, lanza print automaticamente al cargar.
	/// </summary>
	[Parameter] public bool AutoPrint { get; set; }

	/// <summary>
	/// Evento para enviar el documento por email.
	/// </summary>
	[Parameter] public EventCallback<DinaupDocumentEmailRequest> OnSendEmail { get; set; }

	/// <summary>
	/// Template opcional para el formulario de variables (la app host puede inyectar ResponseVariablesU).
	/// </summary>
	[Parameter] public RenderFragment<DinaupVariablesContext> VariablesTemplate { get; set; }

	private DinaupDynamicDocumentDTO _docMetadata;
	private DynamicDocumentsGetResponse.DDocumentC _docInfo;
	private string _documentContent = "";
	private bool _requiresVariables = false;
	private bool _isLoading = true;
	private string _errorMessage = "";
	private string _iframeId = $"dnz-doc-{Guid.NewGuid():N}";
	private Dictionary<string, string> _sendVar = new();

	protected override async Task OnInitializedAsync()
	{
		await UpdateAsync();
	}

	private void HandleVariableConfirm(Dictionary<string, string> variableValues)
	{
		VariableValues = variableValues;
		_ = UpdateAsync();
	}

	public async Task UpdateAsync()
	{
		_isLoading = true;
		_errorMessage = "";
		_requiresVariables = false;
		_documentContent = "";
		StateHasChanged();

		try
		{
			_sendVar = new();

			if (CompatibleDocuments.IsNotEmpty())
			{
				foreach (var currentDocument in CompatibleDocuments)
				{
					string actualKey = currentDocument.VariableList.Variables.Keys.First();
					if (!_sendVar.ContainsKey(actualKey))
						_sendVar.Add(actualKey, VariableValues?.Values?.FirstOrDefault() ?? "");
				}
			}

			if (_sendVar.IsEmpty() && VariableValues.IsNotEmpty())
				_sendVar = VariableValues;

			var response = _sendVar.IsNotEmpty()
				? await Client.DynamicDocuments_ExecuteAsync(DocId, _sendVar)
				: await Client.DynamicDocuments_ExecuteAsync(DocId);

			_docInfo = response.DynamicDocument;
			_documentContent = response.Content ?? "";
			_docMetadata = CompatibleDocuments?.FirstOrDefault(d => d.IDSTR == DocId);

			if (response.Status == 3) // RequiresAsResponse
			{
				_requiresVariables = true;
				VariableValues = new Dictionary<string, string>();
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}

		if (_documentContent.IsNotEmpty())
		{
			try
			{
				await JS.InvokeVoidAsync("setIframeBlob", _iframeId, _documentContent);
				if (AutoPrint)
					await JS.InvokeVoidAsync("printIframe", _iframeId);
			}
			catch { }
		}
	}

	private async Task PrintDocument()
	{
		try
		{
			await JS.InvokeVoidAsync("printIframe", _iframeId);
		}
		catch (Exception ex)
		{
			NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
		}
	}

	private async Task HandleSendEmail()
	{
		if (_docInfo == null || _documentContent.IsEmpty() || !OnSendEmail.HasDelegate) return;

		var request = new DinaupDocumentEmailRequest
		{
			DocumentHtml = _documentContent,
			DocumentTitle = _docInfo.Name ?? ""
		};

		await OnSendEmail.InvokeAsync(request);
	}

	// ── Static helper para abrir como modal ──

	public static async Task OpenAsync(
		DialogService dialogService,
		DinaupClientC client,
		string docId,
		Dictionary<string, string> variableValues = null,
		List<DinaupDynamicDocumentDTO> compatibleDocuments = null,
		string title = "Documento",
		string width = "85%",
		string height = "80%")
	{
		var parameters = new Dictionary<string, object>
		{
			{ nameof(Client), client },
			{ nameof(DocId), docId }
		};

		if (variableValues != null)
			parameters.Add(nameof(VariableValues), variableValues);
		if (compatibleDocuments != null)
			parameters.Add(nameof(CompatibleDocuments), compatibleDocuments);

		var options = new DialogOptions
		{
			Width = width,
			Height = height,
			CloseDialogOnEsc = true,
			Resizable = true,
			Draggable = true,
			ShowClose = true,
			ShowTitle = true
		};

		await dialogService.OpenAsync<DinaupDynamicDocumentView>(title, parameters, options);
	}
}

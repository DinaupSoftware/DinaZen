@namespace DinaZen.Components.DinaupFlex.Components
@using Radzen.Blazor.Rendering
@inject DnzWindowManagerService _windowManager


<ErrorBoundary>
	<div class="dnz-rs-wrap">
		<RadzenFormField Text=@Label Variant="Variant.Flat" class=@(_rootClass) Style=@Style>
			<Start>
				@if (Icon.IsNotEmpty()) {
					<RadzenIcon Icon=@Icon />
				}
			</Start>
			<ChildContent>

				@if (isInitializing && DefaultID.IsNotEmpty()) {
					<div style="width:100%;margin-top:13px;display:flex;justify-content:center;align-items:center;">
						<DnzSkeleton Lines="1" MaxWidth="80%" />
					</div>
				} else {

					<div @ref=containerRef @onclick=@(args => ToggleAsync()) class=@(_isCompact ? "dnz-rs-content" : "dnz-rs-content dnz-rs-with-label")>
						<span style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0;display:block;">
							@if (SelectedRow.IsNotEmpty()) {
								@SelectedRow.Label
							} else if (Placeholder.IsNotEmpty()) {
								<span style="color:var(--rz-input-placeholder-color,#999)">@Placeholder</span>
							}
						</span>
					</div>

				}

			</ChildContent>
			<End>
				<RadzenIcon Icon="arrow_drop_down" Style=@($"font-size:20px;{(Disabled ? "opacity:0.4;" : "cursor:pointer;")}") class=@(Disabled ? "" : "dnz-icon-hover") @onclick=@(args => ToggleAsync()) />
			</End>
		</RadzenFormField>

		@* Toolbar flotante on hover *@
		@if (SelectedRow.IsNotEmpty() || (Disabled == false && OnAdd.HasDelegate)) {
			<div class="dnz-rs-toolbar" style="position:absolute;top:calc(100% + 4px);right:0;display:flex;gap:2px;padding:3px 4px;border-radius:6px;background:var(--rz-panel-background-color,#fff);border:1px solid var(--rz-border-color,#ddd);box-shadow:0 2px 8px rgba(0,0,0,.12);z-index:10;opacity:0;pointer-events:none;transform:translateY(-4px);transition:opacity .15s,transform .15s;">
				@if (SelectedRow.IsNotEmpty()) {
					@if (Disabled == false) {
						<div class="dnz-rs-toolbar-btn" style="display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:4px;cursor:pointer;transition:background .12s;" onclick=@(() => OnClearClick()) title="Quitar">
							<RadzenIcon Icon="close" Style="font-size:14px;color:var(--rz-danger)" />
						</div>
					}
					@if (SelectedRow.SectionID.IsNotEmpty() && (OnOpenRecord.HasDelegate || OpenInWindow)) {
						<div class="dnz-rs-toolbar-btn" style="display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:4px;cursor:pointer;transition:background .12s;" onclick=@(() => OnOpenClick()) title="Abrir">
							<RadzenIcon Icon="open_in_new" Style="font-size:14px" />
						</div>
					}
				} else if (Disabled == false && OnAdd.HasDelegate) {
					<div class="dnz-rs-toolbar-btn" style="display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:4px;cursor:pointer;transition:background .12s;" onclick=@(() => OnAddClick()) title="Agregar">
						<RadzenIcon Icon="add" Style="font-size:14px;color:var(--rz-success)" />
					</div>
				}
			</div>
		}
	</div>
</ErrorBoundary>

<Popup @ref=popup Lazy=true Open="@OnOpen" Style="display:none;position:absolute;padding:5px;border:var(--rz-panel-border);background-color:var(--rz-panel-background-color);" class="dnz-rs-popup">
	<ErrorBoundary>
		<DnzSearchInput BounceValueChanged=@OnDebouncedSearch Class="w-100" />
		<DnzReportView ShowAdd=false ShowSearch=false ShowTitle=false Client=@Client AdminMode=@AdminMode AdvancedFilter=@AdvancedFilter @ref=reportControl OnItemSelect=@(async (x) => { await SelectAsync(x); }) ReportId=@ReportId Limit="20" />
	</ErrorBoundary>
</Popup>

<style>
	.dnz-rs-wrap { position: relative; }
	.dnz-rs-wrap:hover .dnz-rs-toolbar { opacity: 1 !important; pointer-events: auto !important; transform: translateY(0) !important; }
	.dnz-rs-toolbar-btn:hover { background: var(--rz-base-200); }
	.dnz-rs-content { display:flex; align-items:center; padding:4px 10px; border-radius:6px; flex:1; cursor:pointer; min-height:36px; }
	.dnz-rs-with-label { padding-top:20px; min-height:54px; }
	.dnz-rs-required label { color: red !important; }
	.dnz-rs-required label::after { content: "*"; font-size: 0.8em; margin-left: 4px; }
	.dnz-rs-required .rz-form-field-content { background: linear-gradient(0deg, rgba(255, 5, 5, 0.11) 0%, rgba(255, 255, 255, 0) 32%); border-bottom: 2px solid #ffb0b0; }
	.dnz-icon-hover { border-radius: 50%; padding: 2px; transition: background-color 0.15s ease, transform 0.15s ease; }
	.dnz-icon-hover:hover { background-color: rgba(0, 0, 0, 0.08); transform: scale(1.2); }
</style>


@code {

	string _searchText = "";
	bool _isCompact => Label.IsEmpty();

	[Parameter] public string Icon { get; set; }
	[Parameter] public bool AdminMode { get; set; } = false;
	[Parameter, EditorRequired] public DinaupClientC Client { get; set; }

	public async Task ToggleAsync() {
		if (Disabled) return;
		await popup.ToggleAsync(containerRef);
	}

	[Parameter] public string Class { get; set; } = "";

	private async Task OnDebouncedSearch(string value) {
		if (Disabled) return;
		this._searchText = value;
		await reportControl.UpdateSearchAsync(value ?? string.Empty);
	}

	[Parameter] public string KeyboardShortcut { get; set; }

	DnzReportView reportControl;
	ElementReference containerRef;
	Popup popup;

	[Parameter] public string Style { get; set; } = "flex:1";
	[Parameter] public string Placeholder { get; set; }
	[Parameter] public EventCallback<IDinaupRow> SelectedRowChanged { get; set; }
	[Parameter] public IDinaupRow SelectedRow { get; set; }
	[Parameter] public string Label { get; set; }
	[Parameter] public string ReportId { get; set; }
	[Parameter] public bool IsRequired { get; set; }
	[Parameter] public bool Disabled { get; set; }
	[Parameter] public List<FilterCondition> AdvancedFilter { get; set; }
	[Parameter] public EventCallback<Guid> OnAdd { get; set; }
	[Parameter] public EventCallback<IDinaupRow> OnOpenRecord { get; set; }
	[Parameter] public bool OpenInWindow { get; set; } = true;
	[Parameter] public Guid DefaultID { get; set; }

	string _rootClass => "dropdown-menu-component"
		+ ((IsRequired && SelectedRow.IsEmpty()) ? " dnz-rs-required" : "")
		+ (Disabled ? " dropdown-menu-component-disabled" : "")
		+ " " + Class;

	bool isInitializing = true;

	protected override async Task OnInitializedAsync() {
		await base.OnInitializedAsync();
		if (DefaultID.IsNotEmpty()) await SelectByIdAsync(DefaultID);
		isInitializing = false;
	}

	protected override Task OnParametersSetAsync() => base.OnParametersSetAsync();

	public async Task SelectAsync(Dinaup.DinaupBasicInformation data) => await SelectAsync(data.ToDinaupDynamicRowDTO());
	public async Task SelectAsync(DnzRowSelector source) => await SelectAsync(source.SelectedRow);

	public async Task SelectByIdAsync(Guid ID) {
		if (ID.IsNotEmpty()) {
			var paramsX = new ReportRequestParameters(ReportId, 1);
			paramsX.AddFilter("id", "=", ID);
			paramsX.AdminMode = true;
			var result = await Client.Report_GetAsync(paramsX);
			var rows = result.DataList.GetDynamicsRowsOBJ();
			if (rows.IsNotEmpty()) await SelectAsync(rows.FirstOrDefault());
		}
	}

	public async Task SelectAsync(IDinaupRow dataRow) {
		if (dataRow.IsNull()) {
			SelectedRow = null;
			_ = InvokeAsync(this.StateHasChanged);
			_ = SelectedRowChanged.InvokeAsync(null);
		} else {
			SelectedRow = dataRow;
			_ = InvokeAsync(this.StateHasChanged);
			_ = SelectedRowChanged.InvokeAsync(dataRow);
		}
		try { await popup.CloseAsync(); } catch { }
	}

	async Task OnOpen() { if (Disabled) return; }

	private async Task OnAddClick() {
		if (Disabled) return;
		if (OnAdd.HasDelegate) await OnAdd.InvokeAsync();
	}

	private async Task OnClearClick() => _ = SelectAsync((IDinaupRow)null);

	private async Task OnOpenClick() {
		if (this.SelectedRow.IsNull()) return;
		if (OnOpenRecord.HasDelegate) await OnOpenRecord.InvokeAsync(this.SelectedRow);
		else if (OpenInWindow) DnzFormView.OpenAsWindow(_windowManager, Client, SelectedRow.SectionID.STR(), SelectedRow.Id.STR());
	}
}

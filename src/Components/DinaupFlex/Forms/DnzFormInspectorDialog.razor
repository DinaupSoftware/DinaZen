@namespace DinaZen.Components.DinaupFlex.Forms

<DnzDialogLayout Icon="info" Title="Inspeccionar registro">
	<BodyContent>
		<div class="dnz-inspector">
			<div class="dnz-inspector-section">
				<h6 class="dnz-inspector-title"><RadzenIcon Icon="badge" Style="font-size:16px" /> Registro</h6>
				<table class="dnz-inspector-table">
					<tr><td class="dnz-inspector-key">Row ID</td><td class="dnz-inspector-val mono">@RowId</td></tr>
					<tr><td class="dnz-inspector-key">Section ID</td><td class="dnz-inspector-val mono">@SectionId</td></tr>
					<tr><td class="dnz-inspector-key">Seccion</td><td class="dnz-inspector-val">@SectionLabel</td></tr>
				</table>
			</div>

			<div class="dnz-inspector-section">
				<h6 class="dnz-inspector-title"><RadzenIcon Icon="list" Style="font-size:16px" /> Campos (@Fields.Count)</h6>
				<div class="dnz-inspector-fields">
					<table class="dnz-inspector-table dnz-inspector-fields-table">
						<thead>
							<tr>
								<th>Campo</th>
								<th>Valor</th>
								<th>Tipo</th>
								<th style="text-align:center">Estado</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var f in Fields)
							{
								<tr>
									<td class="dnz-inspector-key">@f.Label</td>
									<td class="dnz-inspector-val">@TruncateValue(f.Value)</td>
									<td class="dnz-inspector-val mono" style="font-size:10px; opacity:0.6">@f.FormatEnum</td>
									<td style="text-align:center">
										@if (f.IsLocked) { <span class="badge badge-warning badge-sm">🔒</span> }
										@if (f.IsModified) { <span class="badge e15 badge-sm">✏️</span> }
										@if (f.IsRequired) { <span class="badge badge-danger badge-sm">*</span> }
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</BodyContent>
</DnzDialogLayout>

<style>
	.dnz-inspector {
		padding: 16px 20px;
		display: flex;
		flex-direction: column;
		gap: 20px;
		height: 100%;
		overflow: auto;
	}

	.dnz-inspector-section {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.dnz-inspector-title {
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--rz-text-tertiary-color, #888);
		display: flex;
		align-items: center;
		gap: 6px;
		margin: 0;
	}

	.dnz-inspector-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 12px;
	}

	.dnz-inspector-table th {
		text-align: left;
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--rz-text-tertiary-color, #888);
		padding: 6px 8px;
		border-bottom: 2px solid var(--rz-border-color);
	}

	.dnz-inspector-table td {
		padding: 5px 8px;
		border-bottom: 1px solid var(--rz-border-color);
		vertical-align: top;
	}

	.dnz-inspector-key {
		font-weight: 500;
		white-space: nowrap;
		color: var(--rz-text-secondary-color, #555);
		min-width: 100px;
	}

	.dnz-inspector-val {
		word-break: break-all;
		color: var(--rz-text-color, #1b1d20);
	}

	.dnz-inspector-val.mono,
	.mono {
		font-family: 'SF Mono', 'Cascadia Code', 'Consolas', monospace;
		font-size: 11px;
		user-select: all;
	}

	.dnz-inspector-fields {
		max-height: 100%;
		overflow: auto;
	}

	.dnz-inspector-fields-table tbody tr:hover td {
		background: rgba(52, 129, 229, 0.03);
	}
</style>

@code {
	[Parameter] public string RowId { get; set; } = "";
	[Parameter] public string SectionId { get; set; } = "";
	[Parameter] public string SectionLabel { get; set; } = "";
	[Parameter] public List<Dinaup.VirtualFormDTO.Control> Fields { get; set; } = new();

	private string TruncateValue(string val)
	{
		if (string.IsNullOrEmpty(val)) return "—";
		return val.Length > 120 ? val.Substring(0, 120) + "..." : val;
	}
}

@namespace DinaZen.Components.DinaupFlex.ResponseQuestions

@if (Variables.IsEmpty())
{
	return;
}

<div class="dnz-response-questions">
	<div class="dnz-response-questions-intro">
		<RadzenIcon Icon="help_outline" Style="font-size:32px; color:var(--rz-primary); opacity:0.7" />
		<div>
			<span style="font-weight:600; font-size:14px">Informacion necesaria</span>
			<p class="rz-text-secondary-color" style="font-size:12px; margin:2px 0 0">Completa los campos para continuar.</p>
		</div>
	</div>

	<div class="dnz-response-questions-fields">
		@foreach (var variable in Variables.Values)
		{
			<div @key="@variable.KeyWord" class="dnz-response-questions-field">
				<RadzenLabel Text="@variable.Label" Style="font-weight:500; font-size:13px" />
				@if (variable.Info.IsNotEmpty())
				{
					<span class="rz-text-secondary-color" style="font-size:11px">@variable.Info</span>
				}
				@switch (variable.Format)
				{
					case FieldFormatE.STR:
						<RadzenTextBox Change="@(value => HandleChange(value, variable.KeyWord))" Style="width:100%" />
						break;
					case FieldFormatE.INT:
						<RadzenNumeric TValue="int" Change="@(value => HandleChange(value, variable.KeyWord))" Style="width:100%" />
						break;
					case FieldFormatE.DEC:
						<RadzenNumeric TValue="decimal" Change="@(value => HandleChange(value, variable.KeyWord))" Style="width:100%" />
						break;
					case FieldFormatE.DateAndTime:
					case FieldFormatE.DATE:
					case FieldFormatE.TIME:
						<RadzenDatePicker TValue="DateTime" Style="width:100%"
										  Change="@(value => HandleDateChange(value, variable))"
										  ShowTime="@variable.ShowTime"
										  ShowSeconds="@variable.ShowSeconds"
										  TimeOnly="@(variable.Format == FieldFormatE.TIME)"
										  DateFormat="@variable.DateForma" />
						break;
					case FieldFormatE.BOOL:
						<RadzenCheckBox TValue="bool" Change="@(value => HandleChange(value, variable.KeyWord))" />
						break;
					default:
						<RadzenTextBox Change="@(value => HandleChange(value, variable.KeyWord))" Style="width:100%" />
						break;
				}
			</div>
		}
	</div>

	<div class="dnz-response-questions-actions">
		<RadzenButton Text="Aceptar" Icon="check" ButtonStyle="ButtonStyle.Primary" Click="@OnSubmit" />
	</div>
</div>

<style>
	.dnz-response-questions {
		display: flex;
		flex-direction: column;
		gap: 20px;
		padding: 20px;
		max-width: 520px;
		margin: 0 auto;
	}

	.dnz-response-questions-intro {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.dnz-response-questions-fields {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.dnz-response-questions-field {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.dnz-response-questions-actions {
		display: flex;
		justify-content: flex-end;
		padding-top: 8px;
	}
</style>

@code {

	/// <summary>
	/// Variables requeridas para el formulario.
	/// </summary>
	[Parameter, EditorRequired] public Dictionary<string, DinaupVariableDTO> Variables { get; set; } = new();

	/// <summary>
	/// Valores actuales de las variables.
	/// </summary>
	[Parameter] public Dictionary<string, string> VariableValues { get; set; } = new();

	/// <summary>
	/// Callback al confirmar las variables.
	/// </summary>
	[Parameter] public EventCallback<Dictionary<string, string>> OnConfirm { get; set; }

	protected override void OnParametersSet()
	{
		VariableValues ??= new();
	}

	private void HandleChange(string value, string key)
	{
		VariableValues.AddOrUpdate(key, value);
	}

	private void HandleChange(int value, string key)
	{
		VariableValues.AddOrUpdate(key, value.ToString());
	}

	private void HandleChange(decimal value, string key)
	{
		VariableValues.AddOrUpdate(key, value.ToString(System.Globalization.CultureInfo.InvariantCulture));
	}

	private void HandleChange(bool value, string key)
	{
		VariableValues.AddOrUpdate(key, value ? "1" : "0");
	}

	private void HandleDateChange(DateTime? value, DinaupVariableDTO variable)
	{
		if (value == null) return;

		string formatted = variable.Format switch
		{
			FieldFormatE.TIME => variable.ShowSeconds ? value.Value.ToString("HH:mm:ss") : value.Value.ToString("HH:mm"),
			FieldFormatE.DATE => value.Value.ToString("yyyy-MM-dd"),
			FieldFormatE.DateAndTime => variable.ShowSeconds ? value.Value.ToString("yyyy-MM-dd HH:mm:ss") : value.Value.ToString("yyyy-MM-dd HH:mm"),
			_ => value.Value.ToString("yyyy-MM-dd")
		};

		VariableValues.AddOrUpdate(variable.KeyWord, formatted);
	}

	private void OnSubmit()
	{
		OnConfirm.InvokeAsync(VariableValues);
	}
}

@namespace DinaZen.Components.DinaupFlex.Annotations

<DialogLayout>
	<TitleContent>
		<div class="d-flex align-items-center justify-content-between w-100">
			<div class="d-flex align-items-center gap-2">
				<RadzenIcon Icon="@GetTabIcon()" Style="color:var(--rz-primary); font-size:20px" />
				<span style="font-weight:600">@GetTabTitle()</span>
				@if (!_isLoading && _annotations.IsNotEmpty())
				{
					<RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@_annotations.Count.ToString()" Style="font-size:11px" />
				}
			</div>
			<RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"   Click="@(() => DialogService.Close())" Style="opacity:0.6" />
		</div>
	</TitleContent>
	<BodyContent>
		<div class="dnz-annotations-dialog">
			@* ── Tab selector ── *@
			<RadzenTabs @bind-SelectedIndex="@_selectedTabIndex" Change="@OnTabChanged">
				<Tabs>
					<RadzenTabsItem Text="Comentarios" Icon="chat" />
					<RadzenTabsItem Text="Archivos" Icon="attach_file" />
					<RadzenTabsItem Text="Galeria" Icon="photo_library" />
				</Tabs>
			</RadzenTabs>

			@* ── Annotations list ── *@
			<div class="dnz-annotations-list">
				@if (_isLoading)
				{
					<div class="dnz-annotations-empty">
						<Loader />
					</div>
				}
				else if (_annotations == null || !_annotations.Any())
				{
					<div class="dnz-annotations-empty">
						<RadzenIcon Icon="@GetEmptyIcon()" Style="font-size:48px; opacity:0.3" />
						<p class="rz-text-secondary-color">@GetEmptyMessage()</p>
					</div>
				}
				else
				{
					@foreach (var annotation in _annotations)
					{
						<div class="dnz-annotation-item">
							<div class="dnz-annotation-header">
								<div class="d-flex align-items-center gap-2">
									@if (annotation.Autor.IsNotNull() && annotation.Autor.Name.IsNotEmpty())
									{
										<RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@annotation.Autor.Name" />
									}
									@if (annotation.AnnotationDate != default)
									{
										<span class="rz-text-secondary-color" style="font-size:11px">
											@annotation.AnnotationDate.ToString("dd/MM/yyyy HH:mm")
										</span>
									}
								</div>
							</div>
							@if (annotation.Text.IsNotEmpty())
							{
								<div class="dnz-annotation-body">
									@annotation.Text
								</div>
							}
							@if (annotation.AttachedFiles.IsNotEmpty())
							{
								@foreach (var file in annotation.AttachedFiles)
								{
									<div class="dnz-annotation-file">
										@if (file.IsImage)
										{
											<div class="dnz-annotation-image">
												<img src="@file.url_original" style="max-width:100%; max-height:200px; object-fit:contain; border-radius:6px" />
											</div>
										}
										else
										{
											<div class="d-flex align-items-center gap-1">
												<RadzenIcon Icon="attachment" Style="font-size:14px" />
												<a href="@file.url_original" target="_blank" style="font-size:12px">@(file.Name.IsNotEmpty() ? file.Name : "Archivo adjunto")</a>
											</div>
										}
									</div>
								}
							}
						</div>
					}
				}
			</div>
		</div>
	</BodyContent>
	<FooterContent>
		@if (_pendingFileId != Guid.Empty)
		{
			<div class="d-flex align-items-center gap-1" style="padding:4px 16px 0">
				<span class="dnz-file-attached-badge">
					<RadzenIcon Icon="attachment" Style="font-size:13px" />
					@_pendingFileName
					<RadzenButton Icon="close" Size="ButtonSize.ExtraSmall" Variant="Variant.Text"
								  ButtonStyle="ButtonStyle.Danger" Style="padding:0"
								  Click="@(() => { _pendingFileId = Guid.Empty; _pendingFileName = null; })" />
				</span>
			</div>
		}
		<div class="dnz-annotations-input">
			<RadzenTextBox @bind-Value="@_newMessage" Placeholder="@GetInputPlaceholder()" Style="flex:1" />
			<DnzFileUploaderButton Client="@Client"
								   ButtonIcon="attach_file"
								   ButtonStyle="ButtonStyle.Light"
								   ButtonSize="ButtonSize.Small"
								   MaxFiles="1"
								   OnFilesUploaded="@OnFilesAttached"
								   OnError="@(msg => NotificationService.Notify(NotificationSeverity.Error, msg))" />
			<RadzenButton Icon="send" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
						  Click="SendAnnotation" Disabled="@(_newMessage.IsEmpty() && _pendingFileId == Guid.Empty)" IsBusy="@_isSending" />
		</div>
		<div class="d-flex justify-content-end align-items-center" style="margin-right:20px; margin-top:4px">
			<RadzenButton Click="@(() => DialogService.Close())" ButtonStyle="ButtonStyle.Danger" Text="Cerrar" Icon="close" Variant="Variant.Text" />
		</div>
	</FooterContent>
</DialogLayout>

@code {

	[Parameter] public DinaupClientC Client { get; set; }
	[Parameter] public Guid SectionId { get; set; }
	[Parameter] public Guid RowId { get; set; }
	[Parameter] public AnnotationTypeE InitialType { get; set; } = AnnotationTypeE.Comments;

	private AnnotationTypeE _currentType;
	private int _selectedTabIndex = 0;
	private List<DinaupAnnotationDTO> _annotations = new();
	private bool _isLoading = true;
	private bool _isSending = false;
	private string _newMessage = "";
	private Guid _pendingFileId = Guid.Empty;
	private string _pendingFileName;

	private static readonly AnnotationTypeE[] _tabTypes = { AnnotationTypeE.Comments, AnnotationTypeE.Files, AnnotationTypeE.PublicGallery };

	protected override async Task OnInitializedAsync()
	{
		_currentType = InitialType;
		_selectedTabIndex = Array.IndexOf(_tabTypes, InitialType);
		if (_selectedTabIndex < 0) _selectedTabIndex = 0;
		await LoadAnnotations();
	}

	private async Task OnTabChanged(int index)
	{
		_currentType = _tabTypes[index];
		await LoadAnnotations();
	}

	private async Task LoadAnnotations()
	{
		_isLoading = true;
		StateHasChanged();

		try
		{
			var response = await Client.Annotations_GetAsync(SectionId, RowId, _currentType);
			_annotations = response?.Annotations?.ToList() ?? new();
		}
		catch (Exception ex)
		{
			NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
			_annotations = new();
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}

	private void OnFilesAttached(List<DinaupFileDTO> files)
	{
		var file = files?.FirstOrDefault();
		if (file != null)
		{
			_pendingFileId = file.Id;
			_pendingFileName = file.Name;
		}
		StateHasChanged();
	}

	private async Task SendAnnotation()
	{
		if (_newMessage.IsEmpty() && _pendingFileId == Guid.Empty) return;
		if (_isSending) return;

		_isSending = true;
		StateHasChanged();

		try
		{
			var parameters = new AnotationParameters(SectionId, RowId, _currentType);
			if (_newMessage.IsNotEmpty())
				parameters.WithText(_newMessage);
			if (_pendingFileId != Guid.Empty)
				parameters.WithFile(_pendingFileId);
			await Client.Annotation_PutAsync(parameters);
			_newMessage = "";
			_pendingFileId = Guid.Empty;
			_pendingFileName = null;
			await LoadAnnotations();
		}
		catch (Exception ex)
		{
			NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
		}
		finally
		{
			_isSending = false;
			StateHasChanged();
		}
	}

	private string GetTabIcon() => _currentType switch
	{
		AnnotationTypeE.Comments => "chat",
		AnnotationTypeE.Files => "attach_file",
		AnnotationTypeE.PublicGallery => "photo_library",
		_ => "notes"
	};

	private string GetTabTitle() => _currentType switch
	{
		AnnotationTypeE.Comments => "Comentarios",
		AnnotationTypeE.Files => "Archivos",
		AnnotationTypeE.PublicGallery => "Galeria",
		_ => "Anotaciones"
	};

	private string GetEmptyIcon() => _currentType switch
	{
		AnnotationTypeE.Comments => "chat_bubble_outline",
		AnnotationTypeE.Files => "folder_open",
		AnnotationTypeE.PublicGallery => "photo_library",
		_ => "info"
	};

	private string GetEmptyMessage() => _currentType switch
	{
		AnnotationTypeE.Comments => "No hay comentarios",
		AnnotationTypeE.Files => "No hay archivos adjuntos",
		AnnotationTypeE.PublicGallery => "No hay imagenes en la galeria",
		_ => "Sin datos"
	};

	private string GetInputPlaceholder() => _currentType switch
	{
		AnnotationTypeE.Comments => "Escribe un comentario...",
		AnnotationTypeE.Files => "Descripcion del archivo...",
		AnnotationTypeE.PublicGallery => "Descripcion de la imagen...",
		_ => "Escribe algo..."
	};

	// ── Static helper para abrir como modal ──

	public static async Task OpenAsync(
		DialogService dialogService,
		DinaupClientC client,
		Guid sectionId,
		Guid rowId,
		AnnotationTypeE type)
	{
		var parameters = new Dictionary<string, object>
		{
			{ nameof(Client), client },
			{ nameof(SectionId), sectionId },
			{ nameof(RowId), rowId },
			{ nameof(InitialType), type }
		};

		var options = new DialogOptions
		{
			Width = "650px",
			Height = "80%",
			CloseDialogOnEsc = true,
			Resizable = true,
			Draggable = true,
			ShowClose = false,
			ShowTitle = false
		};

		await dialogService.OpenAsync<DinaupAnnotationsDialog>(null, parameters, options);
	}
}

@namespace DinaZen.Components.DinaupFlex.Reports
@using DinaZen.Components.DinaupFlex.Reports.Provider
@using DinaZen.Components.DinaupFlex.DnzResponseQuestions
@using DinaZen.Components.DinaupFlex.Reports.Filters
@inject DnzWindowManagerService WindowManager
@inject DnzInterceptorService Interceptor
@inject NavigationManager NavigationManager



@if (_isLoading && _dataList == null) {
	<DnzLoader />
} else if (_showResponse && _report?.VariableList?.Variables != null) {
	<DnzResponseQuestions Variables="@_report.VariableList.Variables" VariableValues="@(VariablesValues ?? new())" OnConfirm="@HandleVariableConfirm" />
} else if (_dataList != null) {
	<div class="dnz-report-view">
		@if (ShowTitle) {
			<div class="dnz-report-header">
				@if (_dataList.Section.IsNotNull()) {
					<img onerror="this.src='https://dinaupcdn.com/up/202505/bullet.svg'" src="@($"https://dinaupcdn.com/public/{_dataList.Section.IconoID.STR()}.png")" width="33" height="33" style="border-radius:4px" />
				}
				<span>@Title.IfIsEmpty(_dataList.Title)</span>

				<div class="d-flex align-items-center gap-2 ms-auto">


					<RadzenButton Visible=@(ShowAdd && _dataList?.Section != null) Variant="Variant.Text" Icon="add" Size="ButtonSize.Small" Click="@HandleAddClick" />
					<RadzenTextBox Visible=@ShowSearch Placeholder="Buscar..." Style="max-width:300px" Change="@UpdateSearch" />
					<RadzenButton Variant="Variant.Text" Icon="file_download" Size="ButtonSize.Small" Click="@HandleExportClick" title="Exportar CSV" />
					<RadzenButton Variant="Variant.Text" Icon="refresh" Size="ButtonSize.Small" Click="@(async () => await UpdateAsync())" />
				</div>
			</div>
		}

		<div class="dnz-report-body">
			<RadzenDataGrid @ref="_gridRef" Data="@_rows" TItem="DinaupDynamicRowDTO"
							AllowSorting="true" AllowFiltering="@Filtrable"
							AllowMultiColumnSorting="true" ShowMultiColumnSortingIndex="true"
							AllowColumnPicking="@ShowTitle"
							ColumnsShowingText="Columnas Visibles"
							AllColumnsText="Todas"
							AllowColumnReorder="true"
							Count="@_totalResults"
							PageSize="@Limit" AllowPaging="true"
							PageSizeOptions="@_pageSizeOptions"
							PageSizeText="filas"
							PagerAlwaysVisible="false"
							Density="Density.Compact"
							IsLoading="@_isLoading"
							LoadData="@HandleLoadDataEvent"
							FilterMode="FilterMode.Advanced"
							FilterPopupRenderMode="PopupRenderMode.OnDemand"
							LogicalFilterOperator="LogicalFilterOperator.And"
							RowSelect="@HandleRowSelect"
							AllowColumnResize="true" HeaderTemplate=@ToolBarTemplate
							ShowPagingSummary="true" KeyProperty="ID"
							SettingsChanged=@SaveSettingsAsync LoadSettings="@OnLoadSettings">

				<EmptyTemplate>
					<div class="dnz-report-empty">
						<RadzenIcon Icon="search_off" />
						<span>Sin resultados</span>
					</div>
				</EmptyTemplate>
				<Columns>

					@foreach (var col in _dataList.Columns.Where(c => !c.isColumnHidden)) {
						switch (col.Format) {
							case FieldFormatE.DEC when col.Role == RoleFieldE.Moneda:

								<RadzenDataGridColumn TItem="DinaupDynamicRowDTO" Title="@col.Label" Property="@PropExpr(col)" CssClass="text-right text-nowrap" FooterCssClass="text-right text-nowrap">
									<FilterTemplate Context="data">
										<DnzFilter Column=@col DataColumn=@data />
									</FilterTemplate>
									<Template Context="row">
										<DnzSpanMoney Amount="@row.GetDec(col.Keyword)" AutoColorRed=true />
									</Template>
									<FooterTemplate>
										Suma: <b>@RegionService.ToStringDecimal(_rows.Sum(o => o.GetDec(col.Keyword)))</b>
									</FooterTemplate>
								</RadzenDataGridColumn>
								break;

							case FieldFormatE.DEC:

								<RadzenDataGridColumn TItem="DinaupDynamicRowDTO" Title="@col.Label" Property="@PropExpr(col)" CssClass="text-right text-nowrap" FooterCssClass="text-right text-nowrap">
									<FilterTemplate Context="data">
										<DnzFilter Column=@col DataColumn=@data />
									</FilterTemplate>
									<Template Context="row">
										@if (col.Role == RoleFieldE.Minutos) {
											<DnzSpanMinutes Value=@row.GetDec(col.Keyword) />
										} else {
											<DnzSpanDecimal Value="@row.GetDec(col.Keyword)" />
										}
									</Template>
									<FooterTemplate>
										Suma: <b>@RegionService.ToStringDecimal(_rows.Sum(o => o.GetDec(col.Keyword)))</b>
									</FooterTemplate>
								</RadzenDataGridColumn>
								break;

							case FieldFormatE.INT:

								<RadzenDataGridColumn TItem="DinaupDynamicRowDTO" Title="@col.Label" Property="@PropExpr(col)" CssClass="text-right text-nowrap" FooterCssClass="text-right text-nowrap">
									<FilterTemplate Context="data">
										<DnzFilter Column=@col DataColumn=@data />
									</FilterTemplate>
									<Template Context="row">
										@if (col.Role == RoleFieldE.Minutos) {
											<DnzSpanMinutes Value=@((decimal?)row.GetInt(col.Keyword)) />
										} else {
											@row.GetLegible(col.Keyword)
										}
									</Template>
									<FooterTemplate>
										Suma: <b>@_rows.Sum(o => o.GetInt(col.Keyword))</b>
									</FooterTemplate>
								</RadzenDataGridColumn>
								break;

							case FieldFormatE.DateAndTime:
							case FieldFormatE.DATE:
							case FieldFormatE.TIME:

				<RadzenDataGridColumn TItem="DinaupDynamicRowDTO" Title="@col.Label"
									  Property="@PropExpr(col)"
									  CssClass="text-left text-nowrap">
					<FilterTemplate Context="data">
						<DnzFilter Column=@col DataColumn=@data />
					</FilterTemplate>
					<Template Context="row">
						@{
											DateTime fecha = row.GetDateTime(col.Keyword);
										}
										@if (fecha != default) {
											@if (col.Format == FieldFormatE.DateAndTime) {
												<span>@RegionService.ToLocalFriendlyDateTime(fecha)</span>
											} else if (col.Format == FieldFormatE.DATE) {
												<span>@RegionService.ToLocalFriendlyDate(fecha)</span>
											} else {
												<span>@fecha.ToString("HH:mm")</span>
											}
										}
									</Template>
								</RadzenDataGridColumn>
								break;

							case FieldFormatE.BOOL:

								<RadzenDataGridColumn TItem="DinaupDynamicRowDTO" Title="@col.Label"
													  Property="@PropExpr(col)"
													  CssClass="text-center">
									<FilterTemplate Context="data">
										<DnzFilter Column=@col DataColumn=@data />
									</FilterTemplate>
									<Template Context="row">
										@if (row.GetBool(col.Keyword)) {
											<RadzenBadge Text="Si" BadgeStyle="BadgeStyle.Success" Shade="Shade.Light" />
										} else {
											<RadzenBadge Text="No" BadgeStyle="BadgeStyle.Danger" Shade="Shade.Light" />
										}
									</Template>
								</RadzenDataGridColumn>
								break;

							default:

				<RadzenDataGridColumn TItem="DinaupDynamicRowDTO" Title="@col.Label"
									  Property="@PropExpr(col)"
									  CssClass="text-left text-truncate">
					<FilterTemplate Context="data">
						<DnzFilter Column=@col DataColumn=@data />
					</FilterTemplate>
					<Template Context="row">
						@{
											var value = row.GetLegible(col.Keyword);
										}
										@if (value.IsNotEmpty()) {
											@if (col.BadgetsStyle.IsNotEmpty() || col.Predefined_Values.IsNotEmpty()) {
												<DnzBadgetAutoColor Value=@value BadgetStyle=col.BadgetsStyle />
											} else {
												@value
											}
										}
									</Template>
								</RadzenDataGridColumn>
								break;
						}
					}


				</Columns>
			</RadzenDataGrid>
		</div>
	</div>
} else if (_errorMessage.IsNotEmpty()) {
	<RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">
		@_errorMessage
	</RadzenAlert>
}

@code {

	// ── Parametros ──
	[Parameter] public bool AdminMode { get; set; } = false;

	[Parameter, EditorRequired] public DinaupClientC Client { get; set; }
	[Parameter, EditorRequired] public string ReportId { get; set; } = "";
	[Parameter] public Dictionary<string, string> VariablesValues { get; set; }
	[Parameter] public string QuerySearch { get; set; } = "";
	[Parameter] public List<FilterCondition> AdvancedFilter { get; set; }
	[Parameter] public int Limit { get; set; } = 50;
	[Parameter] public Dictionary<string, bool> Orden { get; set; }
	[Parameter] public bool ShowTitle { get; set; } = true;
	[Parameter] public string Title { get; set; } = "";
	[Parameter] public bool ShowSearch { get; set; } = true;
	[Parameter] public bool Filtrable { get; set; } = true;
	[Parameter] public bool ShowAdd { get; set; } = true;
	[Parameter] public RenderFragment ToolBarTemplate { get; set; }
	[Parameter] public EventCallback<DinaupDynamicRowDTO> OnItemSelect { get; set; }
	[Parameter] public EventCallback OnDataChanged { get; set; }

	// ── Estado ──

	private RadzenDataGrid<DinaupDynamicRowDTO> _gridRef;
	private DinaupReportDTO _report;
	private DinaupReportDataDTO _dataList;
	private List<DinaupDynamicRowDTO> _rows = new();
	private int _totalResults;
	private bool _isLoading = true;
	private bool _showResponse;
	private string _errorMessage = "";
	private Debouncer _searchDebouncer;
	private string _lastQuerySearch = "";
	private LoadDataReportC _lastFilter;
	private static readonly IEnumerable<int> _pageSizeOptions = new int[] { 25, 50, 100, 250, 500 };
	// ── Settings (persistencia columnas visibles) ──

	private string SettingsKey => $"dnz-report-{new Uri(NavigationManager.Uri).AbsolutePath}-{ReportId}";

	private DataGridSettings _settings;


	private async Task LoadSettingsAsync() {
		try {
			var json = await JS.InvokeAsync<string>("localStorage.getItem", SettingsKey);
			if (json.IsNotEmpty())
				_settings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
		} catch { }
	}

	private async Task SaveSettingsAsync(DataGridSettings x) {
		try {
			_settings = x;
			var json = System.Text.Json.JsonSerializer.Serialize(x);
			await JS.InvokeVoidAsync("localStorage.setItem", SettingsKey, json);
		} catch { }

	}

	private void OnLoadSettings(DataGridLoadSettingsEventArgs args) {
		args.Settings = _settings;

	}


	private string PropExpr(DinaupFieldDTO col) {
		var t = Nullable.GetUnderlyingType(col.NetType) ?? col.NetType;
		var n = (Nullable.GetUnderlyingType(col.NetType) != null) ? "?" : "";
		var typeName = t.IsEnum ? "Int32" : t.Name;
		return $@"Convert(Convert(it[""{col.Keyword}""], {typeName}{n}), Object)";
	}



	protected override async Task OnInitializedAsync() {
		_lastQuerySearch = QuerySearch ?? "";
		await LoadDataAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender) {
		if (firstRender) {
		}
	}

	protected override async Task OnParametersSetAsync() {
		var s = QuerySearch ?? "";
		if (s != _lastQuerySearch) {
			_lastQuerySearch = s;
			if (!_isLoading) await LoadDataAsync();
		}
	}

	private void HandleVariableConfirm(Dictionary<string, string> v) {
		VariablesValues = v;
		_ = UpdateAsync();
	}

	public void UpdateSearch(string query) {
		if (QuerySearch == query) return;
		QuerySearch = query;
		_searchDebouncer ??= new Debouncer(async () => await InvokeAsync(async () => { await LoadDataAsync(); StateHasChanged(); }), 800);
		_searchDebouncer.Debounce();
	}

	public async Task UpdateAsync() => await LoadDataAsync(_lastFilter);

	// ── Server-side LoadData ──

	private async void HandleLoadDataEvent(LoadDataArgs args) {
		var ld = new LoadDataReportC {
			Skip = args.Skip,
			Top = args.Top,
			OrderBy = args.OrderBy,
			Filter = args.Filter,
			Filters = args.Filters?.Select(f => new FilterDescriptorC(
				ResolveColId(f.Property), f.FilterValue, MapOp(f.FilterOperator),
				f.SecondFilterValue, MapOp(f.SecondFilterOperator), MapLogical(f.LogicalFilterOperator)
			)).ToList(),
			Sorts = args.Sorts?.Select(s => new OrdenDescriptorC(
				ResolveColId(s.Property), (OrderModeE)s.SortOrder
			)).ToList()
		};

		await LoadDataAsync(ld);

		await InvokeAsync(StateHasChanged);
	}

	private string ResolveColId(string name) {
		if (name.IsNotEmpty() && name.Contains("[\""))
			name = Dinaup.extensions.ParseBetween(ref name, "[\"", "\"]");
		var col = _dataList?.ColumnsByKeyword?.GetM(name);
		return col.IsNotNull() ? (col.ReportColID.IsGUID() ? col.ReportColID : col.NativeName) : name;
	}

	private static FilterFunctionE MapOp(FilterOperator op) => op switch {
		FilterOperator.Equals => FilterFunctionE.Equals,
		FilterOperator.NotEquals => FilterFunctionE.NotEquals,
		FilterOperator.LessThan => FilterFunctionE.LessThan,
		FilterOperator.LessThanOrEquals => FilterFunctionE.LessThanOrEqualTo,
		FilterOperator.GreaterThan => FilterFunctionE.GreaterThan,
		FilterOperator.GreaterThanOrEquals => FilterFunctionE.GreaterThanOrEqualTo,
		FilterOperator.Contains => FilterFunctionE.Contains,
		FilterOperator.StartsWith => FilterFunctionE.StartsWith,
		FilterOperator.EndsWith => FilterFunctionE.EndsWith,
		FilterOperator.DoesNotContain => FilterFunctionE.DoesNotContain,
		FilterOperator.IsEmpty => FilterFunctionE.IsEmpty,
		FilterOperator.IsNotEmpty => FilterFunctionE.IsNotEmpty,
		_ => FilterFunctionE.Contains
	};

	private static LogicalOperatorE MapLogical(LogicalFilterOperator op) =>
		op == LogicalFilterOperator.Or ? LogicalOperatorE.Or : LogicalOperatorE.And;

	// ── Carga de datos ──

	private async Task LoadDataAsync(LoadDataReportC filter = null) {
		if (Limit == 0) Limit = 100;
		filter ??= new LoadDataReportC { Skip = 0, Top = Limit };
		_lastFilter = filter;
		_isLoading = true;
		await LoadSettingsAsync();

		try {
			var p = new ReportRequestParameters(ReportId, Limit) {
				Variables = VariablesValues,
				QuerySearch = QuerySearch,
				Order = Orden,
				Expresion = AdvancedFilter,
				AdminMode = AdminMode
			};
			p.ApplyLoadingConfiguration(filter);

			var response = await Client.Report_GetAsync(p);
			if (response.IsNotNull()) {
				_report = response.Report;
				_showResponse = response.DataList.IsNull();
				_dataList = response.DataList;
				_rows = _dataList?.GetDynamicsRowsOBJ()?.ToList() ?? new();
				_totalResults = _dataList?.TotalResults ?? _rows.Count;
				if (OnDataChanged.HasDelegate)
					try { await OnDataChanged.InvokeAsync(); } catch { }


			}
		} catch (Exception ex) { _errorMessage = ex.Message; } finally {
			_isLoading = false;
			await InvokeAsync(StateHasChanged);
		}

	}

	// ── Export ──

	private async Task HandleExportClick() {
		try {
			var exportFilter = new LoadDataReportC { Skip = 0, Top = _totalResults > 0 ? _totalResults : 10000 };
			if (_lastFilter != null) {
				exportFilter.Filter = _lastFilter.Filter;
				exportFilter.Filters = _lastFilter.Filters;
				exportFilter.Sorts = _lastFilter.Sorts;
				exportFilter.OrderBy = _lastFilter.OrderBy;
			}

			var p = new ReportRequestParameters(ReportId, exportFilter.Top ?? 10000) {
				Variables = VariablesValues,
				QuerySearch = QuerySearch,
				Order = Orden,
				Expresion = AdvancedFilter,
				AdminMode = AdminMode
			};
			p.ApplyLoadingConfiguration(exportFilter);

			var response = await Client.Report_GetAsync(p);
			if (response?.DataList == null) return;

			var allRows = response.DataList.GetDynamicsRowsOBJ()?.ToList() ?? new();
			var columns = response.DataList.Columns.Where(c => !c.isColumnHidden).ToList();
			await ExportToCsvAsync(allRows, columns);
		} catch { }
	}

	private async Task ExportToCsvAsync(List<DinaupDynamicRowDTO> rows, List<DinaupFieldDTO> columns) {
		var sb = new System.Text.StringBuilder();

		// Header
		sb.AppendLine(string.Join(";", columns.Select(c => EscapeCsv(c.Label))));

		// Rows
		foreach (var row in rows) {
			var values = columns.Select(col => {
				return col.Format switch {
					FieldFormatE.DEC => row.GetDec(col.Keyword).ToString(System.Globalization.CultureInfo.InvariantCulture),
					FieldFormatE.INT => row.GetInt(col.Keyword).ToString(),
					FieldFormatE.BOOL => row.GetBool(col.Keyword) ? "Si" : "No",
					FieldFormatE.DateAndTime => row.GetDateTime(col.Keyword) is DateTime dt && dt != default ? dt.ToString("yyyy-MM-dd HH:mm:ss") : "",
					FieldFormatE.DATE => row.GetDateTime(col.Keyword) is DateTime d && d != default ? d.ToString("yyyy-MM-dd") : "",
					FieldFormatE.TIME => row.GetDateTime(col.Keyword) is DateTime t2 && t2 != default ? t2.ToString("HH:mm") : "",
					_ => row.GetLegible(col.Keyword) ?? ""
				};
			});
			sb.AppendLine(string.Join(";", values.Select(v => EscapeCsv(v))));
		}

		var fileName = $"{Title.IfIsEmpty(_dataList?.Title).IfIsEmpty("export")}_{DateTime.Now:yyyyMMdd_HHmm}.csv";
		var bytes = System.Text.Encoding.UTF8.GetPreamble().Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString())).ToArray();
		var base64 = Convert.ToBase64String(bytes);

		await JS.InvokeVoidAsync("eval", $"{{var a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='{fileName.Replace("'", "")}';document.body.appendChild(a);a.click();a.remove();}}");
	}

	private static string EscapeCsv(string value) {
		if (string.IsNullOrEmpty(value)) return "";
		if (value.Contains('"') || value.Contains(';') || value.Contains('\n'))
			return $"\"{value.Replace("\"", "\"\"")}\"";
		return value;
	}

	// ── Acciones de fila ──

	private async Task HandleAddClick() {
		var sectionId = _dataList?.Section?.ID.STR();
		if (sectionId.IsEmpty()) return;

		if (await Interceptor.TryOpenNewRecordAsync(new OpenNewRecordRequest {
			SectionId = sectionId,
			Client = Client
		})) return;

		if (WindowManager != null)
			DnzFormView.OpenAsWindow(WindowManager, Client, sectionId, title: "Nuevo");
		else
			await DnzFormView.OpenAsync(DialogService, Client, sectionId, title: "Nuevo");
	}

	private async Task HandleRowSelect(DinaupDynamicRowDTO row) {
		if (OnItemSelect.HasDelegate) {
			await OnItemSelect.InvokeAsync(row);
			return;
		}

		if (string.IsNullOrEmpty(row.SectionId)) return; // informes agrupados no tienen seccion

		if (await Interceptor.TryOpenRecordAsync(new OpenRecordRequest {
			SectionId = row.SectionId,
			RowId = row.ID,
			Title = row.Title ?? "",
			Client = Client
		})) return;

		// Comportamiento por defecto: abrir formulario en ventana flotante
		if (WindowManager != null)
			DnzFormView.OpenAsWindow(WindowManager, Client, row.SectionId, row.ID, title: row.Title ?? "Formulario");
		else
			await DnzFormView.OpenAsync(DialogService, Client, row.SectionId, row.ID);
	}

	// ── Helpers estaticos para abrir ──

	public static async Task OpenAsync(
		DialogService ds, DinaupClientC client, string reportId,
		Dictionary<string, string> vars = null, string title = "Informe",
		string width = "90%", string height = "80%") {
		var p = new Dictionary<string, object>
		{
			{ nameof(Client), client },
			{ nameof(ReportId), reportId }
		};
		if (vars != null) p.Add(nameof(VariablesValues), vars);

		await ds.OpenAsync<DnzReportView>(title, p, new DialogOptions {
			Width = width,
			Height = height,
			CloseDialogOnEsc = true,
			Resizable = true,
			Draggable = true,
			ShowClose = true,
			ShowTitle = true
		});
	}

	public static string OpenAsWindow(
		DnzWindowManagerService wm, DinaupClientC client, string reportId,
		Dictionary<string, string> vars = null, string title = "Informe", string icon = "analytics") {
		RenderFragment content = b => {
			b.OpenComponent<DnzReportView>(0);
			b.AddAttribute(1, nameof(Client), client);
			b.AddAttribute(2, nameof(ReportId), reportId);
			if (vars != null) b.AddAttribute(3, nameof(VariablesValues), vars);
			b.CloseComponent();
		};
		return wm.Open(new WindowOptions { Title = title, Icon = icon, InitialWidth = 1100, InitialHeight = 650 }, content);
	}
}

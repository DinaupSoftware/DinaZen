@*
    DnzComparisonCardRrhh - "Expected vs Actual" comparison card with difference indicator.
    Visualizes expected and actual ranges as bars on a mini timeline axis,
    with status badges and contextual alerts.

    Origin: play.dinaup.com HumanResources/Dialog/Componentes/ResumenUnionTurnos/ResumenUnionTurnosItemU.razor
*@

<div class="comparison-card @GetStatusClass()">
    <!-- Header -->
    <div class="comparison-header">
        <div class="comparison-header-left">
            <span class="comparison-status-dot"></span>
            <span class="comparison-title">@Title</span>
            @if (string.IsNullOrEmpty(CategoryBadge) == false)
            {
                <span class="comparison-category-badge">@CategoryBadge</span>
            }
        </div>
        <div class="comparison-header-right">
            @GetStatusBadge()
        </div>
    </div>

    <!-- Timeline visual -->
    <div class="comparison-timeline-area">
        @{
            var tl = ComputeTimeline();
        }

        <!-- Hour axis labels -->
        <div class="tl-axis">
            @foreach (var h in tl.AxisHours)
            {
                <span class="tl-axis-label" style="left:@(tl.HourToPercent(h).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%">@h.ToString("00"):00</span>
            }
        </div>

        <!-- Track -->
        <div class="tl-track">
            <!-- Grid lines -->
            @foreach (var h in tl.AxisHours)
            {
                <span class="tl-gridline" style="left:@(tl.HourToPercent(h).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></span>
            }

            <!-- Expected bar -->
            @if (ExpectedStart != null && ExpectedEnd != null)
            {
                <div class="tl-bar tl-bar-expected"
                     style="left:@(tl.TimeToPercent(ExpectedStart.Value).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; width:@(tl.RangePercent(ExpectedStart.Value, ExpectedEnd.Value).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%"
                     title="@ExpectedLabel: @ExpectedStart.Value.ToString("HH:mm") → @ExpectedEnd.Value.ToString("HH:mm")">
                </div>
            }

            <!-- Actual bar -->
            @if (ActualStart != null && ActualEnd != null)
            {
                <div class="tl-bar tl-bar-actual"
                     style="left:@(tl.TimeToPercent(ActualStart.Value).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; width:@(tl.RangePercent(ActualStart.Value, ActualEnd.Value).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%"
                     title="@ActualLabel: @ActualStart.Value.ToString("HH:mm") → @ActualEnd.Value.ToString("HH:mm")">
                </div>
            }
        </div>

        <!-- Legend row -->
        <div class="tl-legend">
            @if (ExpectedStart != null)
            {
                <span class="tl-legend-item">
                    <span class="tl-legend-swatch tl-legend-expected"></span>
                    <span class="tl-legend-label">@ExpectedLabel</span>
                    <span class="tl-legend-value">@ExpectedStart.Value.ToString("HH:mm") → @ExpectedEnd.Value.ToString("HH:mm")</span>
                    <span class="tl-legend-duration">
                        <RadzenIcon Icon="schedule" Style="font-size:12px" />
                        <DnzSpanMinutes Value="@((decimal)GetExpectedDuration().TotalMinutes)" />
                    </span>
                </span>
            }
            @if (ActualStart != null)
            {
                <span class="tl-legend-item">
                    <span class="tl-legend-swatch tl-legend-actual"></span>
                    <span class="tl-legend-label">@ActualLabel</span>
                    <span class="tl-legend-value">@ActualStart.Value.ToString("HH:mm") → @ActualEnd.Value.ToString("HH:mm")</span>
                    <span class="tl-legend-duration">
                        <RadzenIcon Icon="schedule" Style="font-size:12px" />
                        <DnzSpanMinutes Value="@((decimal)GetActualDuration().TotalMinutes)" />
                    </span>
                </span>
            }
        </div>
    </div>

    <!-- Difference chip -->
    @if (ExpectedStart != null && ActualStart != null)
    {
        var diff = GetDifferenceMinutes();
        <div class="comparison-diff-row">
            @if (diff == 0)
            {
                <span class="diff-chip diff-chip-success">
                    <RadzenIcon Icon="done_all" Style="font-size:15px" />
                    @OnTimeText
                </span>
            }
            else if (diff < 0)
            {
                <span class="diff-chip diff-chip-early">
                    <RadzenIcon Icon="north" Style="font-size:15px" />
                    @Math.Abs(diff) min @EarlyText
                </span>
            }
            else
            {
                <span class="diff-chip diff-chip-late">
                    <RadzenIcon Icon="south" Style="font-size:15px" />
                    @diff min @LateText
                </span>
            }

            @if (ShowAbsenceBadge)
            {
                <span class="comparison-badge comparison-badge-warning">@AbsenceText</span>
            }
        </div>
    }

    <!-- Empty states -->
    @if (ExpectedStart == null && ActualStart == null)
    {
        <div class="comparison-empty-state">
            <RadzenIcon Icon="schedule" Style="font-size:18px; opacity:0.4" />
            <span>@ExpectedEmptyText</span>
        </div>
    }
    else if (ExpectedStart != null && ActualStart == null)
    {
        <div class="comparison-empty-state comparison-empty-danger">
            <RadzenIcon Icon="person_off" Style="font-size:16px" />
            <span>@ActualEmptyText</span>
        </div>
    }
    else if (ExpectedStart == null && ActualStart != null)
    {
        <div class="comparison-empty-state comparison-empty-warning">
            <RadzenIcon Icon="event_busy" Style="font-size:16px" />
            <span>@ExpectedEmptyText</span>
        </div>
    }

    <!-- Contextual alert -->
    @{
        var alert = GetAlert();
    }
    @if (alert != null)
    {
        <div class="comparison-alert comparison-alert-@(alert.Value.Type)">
            <RadzenIcon Icon="@alert.Value.Icon" Style="font-size:15px" />
            <span>@alert.Value.Message</span>
        </div>
    }
</div>

@code {

    [Parameter] public string Title { get; set; } = "Shift";
    [Parameter] public string CategoryBadge { get; set; }

    [Parameter] public TimeOnly? ExpectedStart { get; set; }
    [Parameter] public TimeOnly? ExpectedEnd { get; set; }
    [Parameter] public TimeOnly? ActualStart { get; set; }
    [Parameter] public TimeOnly? ActualEnd { get; set; }

    [Parameter] public string ExpectedLabel { get; set; } = "Expected";
    [Parameter] public string ActualLabel { get; set; } = "Actual";
    [Parameter] public string ExpectedEmptyText { get; set; } = "No expected shift";
    [Parameter] public string ActualEmptyText { get; set; } = "Not worked";
    [Parameter] public string OnTimeText { get; set; } = "On time";
    [Parameter] public string EarlyText { get; set; } = "early";
    [Parameter] public string LateText { get; set; } = "late";
    [Parameter] public string AbsenceText { get; set; } = "Absence";

    [Parameter] public bool ShowAbsenceBadge { get; set; }

    [Parameter] public string AlertExpectedNoActual { get; set; } = "Expected shift with no work record";
    [Parameter] public string AlertActualNoExpected { get; set; } = "Work performed outside expected schedule";

    // ── Status logic ──

    private enum ComparisonStatus { Match, Absent, OutOfSchedule, Unknown }

    private ComparisonStatus GetStatus()
    {
        if (ExpectedStart != null && ActualStart != null) return ComparisonStatus.Match;
        if (ExpectedStart != null && ActualStart == null) return ComparisonStatus.Absent;
        if (ExpectedStart == null && ActualStart != null) return ComparisonStatus.OutOfSchedule;
        return ComparisonStatus.Unknown;
    }

    private string GetStatusClass() => GetStatus() switch
    {
        ComparisonStatus.Match => "comparison-status-match",
        ComparisonStatus.Absent => "comparison-status-absent",
        ComparisonStatus.OutOfSchedule => "comparison-status-warning",
        _ => "comparison-status-unknown"
    };

    private RenderFragment GetStatusBadge()
    {
        return GetStatus() switch
        {
            ComparisonStatus.Match => GetMatchBadge(),
            ComparisonStatus.Absent => @<span class="comparison-badge comparison-badge-danger">@AbsenceText</span>,
            ComparisonStatus.OutOfSchedule => @<span class="comparison-badge comparison-badge-warning">Out of schedule</span>,
            _ => @<span class="comparison-badge comparison-badge-neutral">Unknown</span>
        };
    }

    private RenderFragment GetMatchBadge()
    {
        var diff = GetDifferenceMinutes();
        if (Math.Abs(diff) <= 5)
            return @<span class="comparison-badge comparison-badge-success">@OnTimeText</span>;
        if (diff < 0)
            return @<span class="comparison-badge comparison-badge-info">Early</span>;
        return @<span class="comparison-badge comparison-badge-warning">Late</span>;
    }

    // ── Time calculations ──

    private int GetDifferenceMinutes()
    {
        if (ExpectedStart == null || ActualStart == null) return 0;
        var diff = ActualStart.Value.ToTimeSpan() - ExpectedStart.Value.ToTimeSpan();
        return (int)diff.TotalMinutes;
    }

    private TimeSpan GetExpectedDuration()
    {
        if (ExpectedStart == null || ExpectedEnd == null) return TimeSpan.Zero;
        var diff = ExpectedEnd.Value.ToTimeSpan() - ExpectedStart.Value.ToTimeSpan();
        return diff < TimeSpan.Zero ? diff + TimeSpan.FromDays(1) : diff;
    }

    private TimeSpan GetActualDuration()
    {
        if (ActualStart == null || ActualEnd == null) return TimeSpan.Zero;
        var diff = ActualEnd.Value.ToTimeSpan() - ActualStart.Value.ToTimeSpan();
        return diff < TimeSpan.Zero ? diff + TimeSpan.FromDays(1) : diff;
    }

    private (string Type, string Icon, string Message)? GetAlert()
    {
        if (ExpectedStart != null && ActualStart == null)
            return ("danger", "warning", AlertExpectedNoActual);
        if (ExpectedStart == null && ActualStart != null)
            return ("warning", "info", AlertActualNoExpected);
        return null;
    }

    // ── Timeline computation ──

    private record TimelineData(int StartHour, int EndHour, List<int> AxisHours)
    {
        public double HourToPercent(int hour)
        {
            if (EndHour == StartHour) return 0;
            return (double)(hour - StartHour) / (EndHour - StartHour) * 100.0;
        }

        public double TimeToPercent(TimeOnly time)
        {
            double totalMin = time.Hour * 60.0 + time.Minute;
            double startMin = StartHour * 60.0;
            double endMin = EndHour * 60.0;
            if (endMin == startMin) return 0;
            return (totalMin - startMin) / (endMin - startMin) * 100.0;
        }

        public double RangePercent(TimeOnly from, TimeOnly to)
        {
            double fromMin = from.Hour * 60.0 + from.Minute;
            double toMin = to.Hour * 60.0 + to.Minute;
            if (toMin < fromMin) toMin += 1440;
            double startMin = StartHour * 60.0;
            double endMin = EndHour * 60.0;
            if (endMin == startMin) return 0;
            return (toMin - fromMin) / (endMin - startMin) * 100.0;
        }
    }

    private TimelineData ComputeTimeline()
    {
        var times = new List<TimeOnly>();
        if (ExpectedStart != null) times.Add(ExpectedStart.Value);
        if (ExpectedEnd != null) times.Add(ExpectedEnd.Value);
        if (ActualStart != null) times.Add(ActualStart.Value);
        if (ActualEnd != null) times.Add(ActualEnd.Value);

        if (times.Count == 0)
            return new TimelineData(8, 18, new List<int> { 8, 10, 12, 14, 16, 18 });

        int minHour = times.Min(t => t.Hour);
        int maxHour = times.Max(t => t.Hour) + 1;

        // Padding: 1h before and after, clamped to 0–24
        int start = Math.Max(0, minHour - 1);
        int end = Math.Min(24, maxHour + 1);

        // Ensure minimum 3h span
        if (end - start < 3)
        {
            int mid = (start + end) / 2;
            start = Math.Max(0, mid - 2);
            end = Math.Min(24, mid + 2);
        }

        // Generate axis hours (every 1-2 hours depending on span)
        int span = end - start;
        int step = span <= 6 ? 1 : 2;
        var hours = new List<int>();
        for (int h = start; h <= end; h += step)
            hours.Add(h);

        return new TimelineData(start, end, hours);
    }
}

@*
    DnzTimelineBarRrhh - Horizontal bar positioned on a 24h timeline axis.
    Calculates left% and width% from TimeOnly Start/End.
    Supports "phantom time" (if no end and date is today, extends to current time).
*@

@using DinaZen.Components.Rrhh.Models

@if (Start != null)
{
    <div title="@_tooltip"    @onclick="OnClick"      class="@CssClasses"    style="left:@(_leftPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; width:@(_widthPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%">
        <RadzenIcon Icon="@StyleIcon" class="tlbar-icon" />
        @if (ShowLabel && _widthPct > 8)
        {
            <span class="tlbar-label">@_timeLabel</span>
        }
        @if (ChildContent != null)
        {
            @ChildContent
        }
    </div>
}

@code {

    [Parameter, EditorRequired]
    public DateOnly? Date { get; set; }

    [Parameter, EditorRequired]
    public TimeOnly? Start { get; set; }

    [Parameter, EditorRequired]
    public TimeOnly? End { get; set; }

    [Parameter]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public string Class { get; set; } = "";

    /// <summary>
    /// Predefined visual style. When set to a value other than None,
    /// the component applies a built-in design (color and icon).
    /// Can be combined with <see cref="Class"/> for additional customization.
    /// </summary>
    [Parameter]
    public TimelineBarStyleRrhh Style { get; set; } = TimelineBarStyleRrhh.None;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public bool ShowPhantomTime { get; set; } = true;

    /// <summary>Show time range label inside the bar when there's enough room.</summary>
    [Parameter]
    public bool ShowLabel { get; set; } = true;

    /// <summary>First hour of the axis range (must match the parent DnzTimelineRrhh.StartHour).</summary>
    [Parameter]
    public int AxisStartHour { get; set; } = 0;

    /// <summary>Last hour of the axis range (must match the parent DnzTimelineRrhh.EndHour).</summary>
    [Parameter]
    public int AxisEndHour { get; set; } = 24;

    /// <summary>
    /// Reference "now" used to detect today and phantom-end.
    /// Defaults to <c>DateTime.Now</c> — pass a culture-aware value (e.g. RegionService.LocalNow()) for accuracy in server-side scenarios.
    /// </summary>
    [Parameter]
    public DateTime? Now { get; set; }

    private bool _isPhantom;
    private string _tooltip = "";
    private string _timeLabel = "";
    private double _leftPct;
    private double _widthPct;

    private string StyleIcon => _isPhantom ? "hourglass_empty" : Style switch
    {
        TimelineBarStyleRrhh.Holiday => "celebration",
        TimelineBarStyleRrhh.SickLeave => "local_hospital",
        TimelineBarStyleRrhh.Rest => "bedtime",
        TimelineBarStyleRrhh.OfficialShift => "event",
        TimelineBarStyleRrhh.ActualShift => "check_circle",
        TimelineBarStyleRrhh.Absence => "person_off",
        TimelineBarStyleRrhh.Vacation => "beach_access",
        TimelineBarStyleRrhh.Punch => "fingerprint",
        _ => "schedule"
    };

    private string StyleDisplayName => Style switch
    {
        TimelineBarStyleRrhh.Holiday => "Festivo",
        TimelineBarStyleRrhh.SickLeave => "Baja médica",
        TimelineBarStyleRrhh.Rest => "Descanso",
        TimelineBarStyleRrhh.OfficialShift => "Turno oficial",
        TimelineBarStyleRrhh.ActualShift => "Turno realizado",
        TimelineBarStyleRrhh.Absence => "Ausencia",
        TimelineBarStyleRrhh.Vacation => "Vacaciones",
        TimelineBarStyleRrhh.Punch => "Fichaje",
        _ => ""
    };

    private string CssClasses
    {
        get
        {
            var baseClass = "timeline-bar-rrhh";
            var phantomClass = _isPhantom ? "tlbar-phantom" : "";
            var styleClass = Style switch
            {
                TimelineBarStyleRrhh.Holiday => "tlbar-holiday",
                TimelineBarStyleRrhh.SickLeave => "tlbar-sick-leave",
                TimelineBarStyleRrhh.Rest => "tlbar-rest",
                TimelineBarStyleRrhh.OfficialShift => "tlbar-official-shift",
                TimelineBarStyleRrhh.ActualShift => "tlbar-actual-shift",
                TimelineBarStyleRrhh.Absence => "tlbar-absence",
                TimelineBarStyleRrhh.Vacation => "tlbar-vacation",
                TimelineBarStyleRrhh.Punch => "tlbar-punch",
                _ => ""
            };
            return $"{baseClass} {styleClass} {phantomClass} {Class}".Trim();
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (Start == null) return;

        var now = Now ?? DateTime.Now;
        var currentTime = TimeOnly.FromDateTime(now);
        var isToday = Date == DateOnly.FromDateTime(now);
        bool noEnd = End == null || End == TimeOnly.MinValue;

        _isPhantom = noEnd && isToday && ShowPhantomTime;

        TimeOnly effectiveEnd;

        if (_isPhantom)
        {
            effectiveEnd = currentTime > Start.Value ? currentTime : new TimeOnly(23, 59, 59);
        }
        else if (noEnd)
        {
            effectiveEnd = new TimeOnly(23, 59, 59);
        }
        else
        {
            effectiveEnd = End.Value;
        }

        double axisStart = Math.Clamp(AxisStartHour, 0, 23) * 60d;
        double axisEndRaw = Math.Clamp(AxisEndHour, 0, 24) * 60d;
        bool axisCrossesMidnight = axisEndRaw <= axisStart;
        double axisEnd = axisCrossesMidnight ? axisEndRaw + 1440d : axisEndRaw;
        double axisSpan = axisEnd - axisStart;
        if (axisSpan <= 0) axisSpan = 1440d;

        double startMinutes = Start.Value.Hour * 60 + Start.Value.Minute;
        double endMinutes = effectiveEnd.Hour * 60 + effectiveEnd.Minute;

        if (axisCrossesMidnight && startMinutes < axisStart) startMinutes += 1440d;
        if (endMinutes < startMinutes) endMinutes += 1440d;

        double duration = Math.Max(_isPhantom ? 10d : 30d, endMinutes - startMinutes);

        _leftPct = ((startMinutes - axisStart) / axisSpan) * 100d;
        _widthPct = (duration / axisSpan) * 100d;

        string endStr = _isPhantom ? "Ahora" : effectiveEnd.ToString("HH:mm");
        _timeLabel = $"{Start.Value:HH:mm} – {endStr}";

        var dur = TimeSpan.FromMinutes(duration);
        string durStr = dur.Hours > 0 ? $"{dur.Hours}h {dur.Minutes}m" : $"{dur.Minutes}m";
        string typeStr = string.IsNullOrEmpty(StyleDisplayName) ? "" : $"{StyleDisplayName}\n";
        _tooltip = $"{typeStr}{Start.Value:HH:mm} – {endStr} ({durStr})";
    }
}

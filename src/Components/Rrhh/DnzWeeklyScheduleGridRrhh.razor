@*
    DnzWeeklyScheduleGridRrhh - Grid visual de horario semanal agrupado por dia con franjas horarias.
    Recibe datos ya procesados (sin dependencias de servicios).

    Origen: play.dinaup.com HumanResources/Components/HorarioCard.razor
*@

@using DinaZen.Components.Rrhh.Models
@using System.Globalization

@if (Items != null && Items.Any())
{
    <div class="weekly-schedule-grid">
        @foreach (var dayGroup in Items.GroupBy(h => h.Day).OrderBy(g => GetSortOrder(g.Key)))
        {
            var slots = dayGroup.OrderBy(e => e.From).ToList();
            var totalMinutes = slots.Sum(s => (int)s.Duration.TotalMinutes);
            var totalHours = totalMinutes / 60;
            var remainMinutes = totalMinutes % 60;

            <div class="schedule-day-card">
                <div class="schedule-day-header">
                    <span class="schedule-day-abbr">@GetDayAbbr(dayGroup.Key)</span>
                    <span class="schedule-day-name">@GetDayName(dayGroup.Key)</span>
                </div>
                <div class="schedule-slots">
                    @foreach (var slot in slots)
                    {
                        <div class="schedule-slot">
                            <span class="schedule-time">@slot.From.ToString("HH:mm")</span>
                            <span class="schedule-separator">
                                <RadzenIcon Icon="arrow_forward" Style="font-size:10px; opacity:0.4" />
                            </span>
                            <span class="schedule-time">@slot.To.ToString("HH:mm")</span>
                        </div>
                    }
                </div>
                <div class="schedule-day-footer">
                    <RadzenIcon Icon="schedule" Style="font-size:12px" />
                    <span>@(totalHours)h@(remainMinutes > 0 ? $" {remainMinutes}m" : "")</span>
                </div>
            </div>
        }
    </div>
}

@code {

    [Parameter, EditorRequired]
    public IEnumerable<ScheduleItemRrhh> Items { get; set; }

    [Parameter]
    public CultureInfo Culture { get; set; }

    [Parameter]
    public DayOfWeek FirstDayOfWeek { get; set; } = DayOfWeek.Monday;

    private CultureInfo GetCulture() => Culture ?? RegionService?.Culture ?? CultureInfo.CurrentCulture;

    private string GetDayName(DayOfWeek day)
    {
        var name = GetCulture().DateTimeFormat.GetDayName(day);
        return char.ToUpper(name[0]) + name.Substring(1);
    }

    private string GetDayAbbr(DayOfWeek day)
    {
        var name = GetCulture().DateTimeFormat.GetAbbreviatedDayName(day);
        return name.Length > 0 ? char.ToUpper(name[0]) + name.Substring(1, Math.Min(2, name.Length - 1)) : name;
    }

    private int GetSortOrder(DayOfWeek day)
    {
        int offset = (int)day - (int)FirstDayOfWeek;
        if (offset < 0) offset += 7;
        return offset;
    }

}

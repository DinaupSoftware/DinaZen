@*
    TimelineBarRrhh - Horizontal bar positioned on a 24h timeline axis.
    Calculates left% and width% from TimeOnly Start/End.
    Supports "phantom time" (if no end and date is today, extends to current time).

    Origin: play.dinaup.com HumanResources/Components/TLEmpleado/TLBarU.razor
*@

@using DinaZen.Components.Rrhh.Models

<div title="@_tooltip"
     @onclick="OnClick"
     class="@CssClasses"
     style="left:@(_leftPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; width:@(_widthPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%">
    <RadzenIcon Icon="@StyleIcon" class="tlbar-icon" />
    @if (ShowLabel && _widthPct > 8)
    {
        <span class="tlbar-label">@_timeLabel</span>
    }
    @if (ChildContent != null)
    {
        @ChildContent
    }
</div>

@code {

    [Parameter, EditorRequired]
    public DateOnly? Date { get; set; }

    [Parameter, EditorRequired]
    public TimeOnly? Start { get; set; }

    [Parameter, EditorRequired]
    public TimeOnly? End { get; set; }

    [Parameter]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public string Class { get; set; } = "";

    /// <summary>
    /// Predefined visual style. When set to a value other than None,
    /// the component applies a built-in design (color and icon).
    /// Can be combined with <see cref="Class"/> for additional customization.
    /// </summary>
    [Parameter]
    public TimelineBarStyleRrhh Style { get; set; } = TimelineBarStyleRrhh.None;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public bool ShowPhantomTime { get; set; } = true;

    /// <summary>
    /// Show time range label inside the bar when there's enough room.
    /// </summary>
    [Parameter]
    public bool ShowLabel { get; set; } = true;

    private bool _isPhantom;
    private string _tooltip = "";
    private string _timeLabel = "";
    private decimal _leftPct;
    private decimal _widthPct;

    private string StyleIcon => Style switch
    {
        TimelineBarStyleRrhh.Holiday => "celebration",
        TimelineBarStyleRrhh.SickLeave => "local_hospital",
        TimelineBarStyleRrhh.Rest => "bedtime",
        TimelineBarStyleRrhh.OfficialShift => "event",
        TimelineBarStyleRrhh.ActualShift => "check_circle",
        TimelineBarStyleRrhh.Absence => "person_off",
        TimelineBarStyleRrhh.Vacation => "beach_access",
        _ => "schedule"
    };

    private string StyleDisplayName => Style switch
    {
        TimelineBarStyleRrhh.Holiday => "Holiday",
        TimelineBarStyleRrhh.SickLeave => "Sick leave",
        TimelineBarStyleRrhh.Rest => "Rest",
        TimelineBarStyleRrhh.OfficialShift => "Official shift",
        TimelineBarStyleRrhh.ActualShift => "Actual shift",
        TimelineBarStyleRrhh.Absence => "Absence",
        TimelineBarStyleRrhh.Vacation => "Vacation",
        _ => ""
    };

    private string CssClasses
    {
        get
        {
            var baseClass = "timeline-bar-rrhh";
            var phantomClass = _isPhantom ? "tlbar-phantom" : "";
            var styleClass = Style switch
            {
                TimelineBarStyleRrhh.Holiday => "tlbar-holiday",
                TimelineBarStyleRrhh.SickLeave => "tlbar-sick-leave",
                TimelineBarStyleRrhh.Rest => "tlbar-rest",
                TimelineBarStyleRrhh.OfficialShift => "tlbar-official-shift",
                TimelineBarStyleRrhh.ActualShift => "tlbar-actual-shift",
                TimelineBarStyleRrhh.Absence => "tlbar-absence",
                TimelineBarStyleRrhh.Vacation => "tlbar-vacation",
                _ => ""
            };
            return $"{baseClass} {styleClass} {phantomClass} {Class}".Trim();
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (Start == null) return;

        var currentTime = RegionService.LocalNow().ToTimeOnly();
        var isToday = Date == RegionService.DateOnlyNow();
        bool noEnd = End == null || End == TimeOnly.MinValue;

        _isPhantom = noEnd && isToday && ShowPhantomTime;

        TimeOnly effectiveEnd;

        if (_isPhantom)
        {
            effectiveEnd = currentTime > Start.Value ? currentTime : new TimeOnly(23, 59, 59);
        }
        else if (noEnd)
        {
            effectiveEnd = new TimeOnly(23, 59, 59);
        }
        else
        {
            effectiveEnd = End.Value;
        }

        decimal startMinutes = Start.Value.Hour * 60 + Start.Value.Minute;
        decimal endMinutes = effectiveEnd.Hour * 60 + effectiveEnd.Minute;
        decimal duration = Math.Max(_isPhantom ? 10m : 30m, endMinutes - startMinutes);

        _leftPct = (startMinutes / 1440.0m) * 100m;
        _widthPct = (duration / 1440.0m) * 100m;

        try
        {
            string endStr = _isPhantom ? "Now" : effectiveEnd.ToString("HH:mm");
            _timeLabel = $"{Start.Value:HH:mm} – {endStr}";

            // Rich tooltip
            var dur = TimeSpan.FromMinutes((double)duration);
            string durStr = dur.Hours > 0 ? $"{dur.Hours}h {dur.Minutes}m" : $"{dur.Minutes}m";
            string typeStr = string.IsNullOrEmpty(StyleDisplayName) ? "" : $"{StyleDisplayName}\n";
            _tooltip = $"{typeStr}{Start.Value:HH:mm} – {endStr} ({durStr})";
        }
        catch
        {
            _timeLabel = "";
            _tooltip = "";
        }
    }

}

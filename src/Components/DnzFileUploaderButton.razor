@namespace DinaZen.Components
@using Microsoft.AspNetCore.Components.Forms

<span style="position:relative; display:inline-flex">
	<RadzenButton Icon="@ButtonIcon" Text="@ButtonText"
				  ButtonStyle="@ButtonStyle" Size="@ButtonSize"
				  Variant="@ButtonVariant"
				  Disabled="@(Disabled || _isUploading)"
				  IsBusy="@_isUploading"
				  Click="@TriggerFileInput" />
	<InputFile @ref="_inputFileRef"
			   OnChange="@OnFileSelected"
			   accept="@AcceptString"
			   class="dnz-file-btn-input"
			   id="@_inputId"
			   disabled="@Disabled" />
</span>

@code {

	[Parameter] public DinaupClientC Client { get; set; }
	[Parameter] public string[] AcceptExtensions { get; set; } = [];
	[Parameter] public long MaxSizeBytes { get; set; } = 80 * 1024 * 1024;
	[Parameter] public bool Disabled { get; set; }
	[Parameter] public string ButtonText { get; set; }
	[Parameter] public string ButtonIcon { get; set; } = "attach_file";
	[Parameter] public ButtonStyle ButtonStyle { get; set; } = ButtonStyle.Light;
	[Parameter] public ButtonSize ButtonSize { get; set; } = ButtonSize.Small;
	[Parameter] public Variant ButtonVariant { get; set; } = Variant.Outlined;
	[Parameter] public EventCallback<DinaupFileDTO> OnFileUploaded { get; set; }
	[Parameter] public EventCallback<string> OnError { get; set; }

	private InputFile _inputFileRef;
	private bool _isUploading;
	private readonly string _inputId = "dnz-fbtn-" + Guid.NewGuid().ToString("N")[..8];

	private string AcceptString => AcceptExtensions.Length > 0
		? string.Join(",", AcceptExtensions.Select(e => e.StartsWith(".") ? e : "." + e))
		: null;

	private async Task TriggerFileInput()
	{
		await JS.InvokeVoidAsync("eval", $"document.getElementById('{_inputId}').click()");
	}

	private async Task OnFileSelected(InputFileChangeEventArgs e)
	{
		if (Client == null)
		{
			await OnError.InvokeAsync("No se proporcionó Client");
			return;
		}

		var file = e.File;
		_isUploading = true;
		StateHasChanged();

		try
		{
			if (file.Size > MaxSizeBytes)
			{
				await OnError.InvokeAsync($"{file.Name} supera el límite de {MaxSizeBytes / 1024 / 1024}MB");
				return;
			}

			if (AcceptExtensions.Length > 0)
			{
				var ext = System.IO.Path.GetExtension(file.Name).TrimStart('.').ToLowerInvariant();
				var allowed = AcceptExtensions.Select(x => x.TrimStart('.').ToLowerInvariant());
				if (!allowed.Contains(ext))
				{
					await OnError.InvokeAsync($"{file.Name}: extensión .{ext} no permitida");
					return;
				}
			}

			using var stream = file.OpenReadStream(maxAllowedSize: MaxSizeBytes);
			using var ms = new System.IO.MemoryStream();
			await stream.CopyToAsync(ms);
			var bytes = ms.ToArray();

			var response = await Client.File_UploadBytesAsync(bytes, file.Name);

			if (response?.FileData != null)
				await OnFileUploaded.InvokeAsync(response.FileData);
		}
		catch (Exception ex)
		{
			await OnError.InvokeAsync($"Error subiendo {file.Name}: {ex.Message}");
		}
		finally
		{
			_isUploading = false;
			StateHasChanged();
		}
	}
}

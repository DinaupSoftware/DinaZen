@namespace DinaZen.Components
@implements IAsyncDisposable

<span id="@_selector" style="display:inline-flex; align-items:center; gap:6px">
	@if (UseDashboard == false && _isUploading)
	{
		<RadzenProgressBarCircular Value="@_uploadProgress"  Size="ProgressBarCircularSize.ExtraSmall" ShowValue="false"
								   ProgressBarStyle="ProgressBarStyle.Primary" Mode="@(_uploadProgress > 0 ? ProgressBarMode.Determinate : ProgressBarMode.Indeterminate)" />
		<span style="font-size:12px; white-space:nowrap">Subiendo @(_uploadProgress)%</span>
	}
	else if (UseDashboard == false && _isRegistering)
	{
		<RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.ExtraSmall" ProgressBarStyle="ProgressBarStyle.Success" />
		<span style="font-size:12px">Confirmando...</span>
	}
	else
	{
		<RadzenButton Icon="@ButtonIcon" Text="@ButtonText"
					  ButtonStyle="@ButtonStyle" Size="@ButtonSize"
					  Variant="@ButtonVariant"
					  Disabled="@Disabled" />
	}
</span>

@code {

	[Parameter] public DinaupClientC Client { get; set; }
	[Parameter] public string PresignEndpoint { get; set; } = "/file/upload/sign";
	[Parameter] public EventCallback<List<DinaupFileDTO>> OnFilesUploaded { get; set; }
	[Parameter] public EventCallback<PresignUploadResult> OnEachFileUploaded { get; set; }
	[Parameter] public string[] AcceptExtensions { get; set; } = [];
	[Parameter] public long MaxSizeBytes { get; set; } = 150 * 1024 * 1024;
	[Parameter] public int MaxFiles { get; set; } = 1000;
	[Parameter] public bool Disabled { get; set; }
	[Parameter] public string ButtonText { get; set; }
	[Parameter] public string ButtonIcon { get; set; } = "attach_file";
	[Parameter] public ButtonStyle ButtonStyle { get; set; } = ButtonStyle.Secondary;
	[Parameter] public ButtonSize ButtonSize { get; set; } = ButtonSize.Small;
	[Parameter] public Variant ButtonVariant { get; set; } = Variant.Outlined;
	/// <summary>When true, opens the Uppy Dashboard modal (drag & drop, progress UI) instead of the native file picker.</summary>
	[Parameter] public bool UseDashboard { get; set; }
	[Parameter] public string Note { get; set; }
	[Parameter] public EventCallback<string> OnError { get; set; }

	private readonly string _selector = "dnz-fbtn-" + Guid.NewGuid().ToString("N")[..8];
	private DotNetObjectReference<DnzFileUploaderButton> _dotNetRef;
	private bool _initialized;
	private bool _isUploading;
	private bool _isRegistering;
	private int _uploadProgress;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender && Disabled == false)
		{
			await InitUppy();
		}
	}

	private async Task InitUppy()
	{
		if (_initialized) return;
		_dotNetRef ??= DotNetObjectReference.Create(this);

		var extensions = AcceptExtensions.Length > 0
			? AcceptExtensions.Select(e => e.StartsWith(".") ? e : "." + e).ToArray()
			: Array.Empty<string>();

		var jsFunc = UseDashboard ? "window.dnzUppy_initDashboard" : "window.dnzUppy_initButton";
		await JS.InvokeVoidAsync(jsFunc, "#" + _selector, _dotNetRef, new {
			signEndpoint = PresignEndpoint,
			allowedExtensions = extensions,
			maxFileSize = MaxSizeBytes,
			maxFiles = MaxFiles
		});

		_initialized = true;
	}

	[JSInvokable]
	public void JsUploadStarted()
	{
		_isUploading = true;
		_uploadProgress = 0;
		InvokeAsync(StateHasChanged);
	}

	[JSInvokable]
	public void JsUploadProgress(int progress)
	{
		_uploadProgress = progress;
		_isUploading = true;
		InvokeAsync(StateHasChanged);
	}

	[JSInvokable]
	public void JsUploadCancelled()
	{
		_isUploading = false;
		_uploadProgress = 0;
		InvokeAsync(StateHasChanged);
	}

	[JSInvokable]
	public async Task JsFileUploaded(PresignUploadResult file)
	{
		if (OnEachFileUploaded.HasDelegate)
			await OnEachFileUploaded.InvokeAsync(file);
	}

	[JSInvokable]
	public async Task JsAllUploadsComplete(List<PresignUploadResult> files)
	{
		_isUploading = false;
		_uploadProgress = 0;

		// Per-file mode: caller handles registration in OnEachFileUploaded, skip batch registration
		if (OnEachFileUploaded.HasDelegate)
		{
			await InvokeAsync(StateHasChanged);
			return;
		}

		if (files.IsEmpty() || Client == null)
		{
			await InvokeAsync(StateHasChanged);
			return;
		}

		_isRegistering = true;
		await InvokeAsync(StateHasChanged);

		List<DinaupFileDTO> registered = new();

		foreach (var file in files)
		{
			if (file.Url.IsEmpty()) continue;
			try
			{
				var response = await Client.File_UploadURLAsync(file.Url, file.FileName);
				if (response?.FileData != null)
					registered.Add(response.FileData);
			}
			catch (Exception ex)
			{
				await OnError.InvokeAsync($"Error registrando {file.FileName}: {ex.Message}");
			}
		}

		_isRegistering = false;

		if (registered.IsNotEmpty())
			await OnFilesUploaded.InvokeAsync(registered);

		await InvokeAsync(StateHasChanged);
	}

	[JSInvokable]
	public async Task JsUploadError(string fileName, string error)
	{
		_isUploading = false;
		_uploadProgress = 0;
		await InvokeAsync(StateHasChanged);
		await OnError.InvokeAsync($"Error subiendo {fileName}: {error}");
	}

	public async ValueTask DisposeAsync()
	{
		if (_initialized)
		{
			try { await JS.InvokeVoidAsync("window.dnzUppy_destroyButton", "#" + _selector); } catch { }
		}
		_dotNetRef?.Dispose();
	}
}

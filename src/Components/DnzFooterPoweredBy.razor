@using Dinaup
@using Microsoft.AspNetCore.Components

<footer class="@GetFooterClass()">
    @if (Style == FooterStyleType.Compact)
    {
        <p class="dnz-footer-powered__compact-text">
            <i>Powered by</i>
            <a href="https://dinaup.com"
               target="_blank"
               rel="noopener noreferrer"
               title="Dinaup"
               class="dnz-footer-powered__compact-logo">
                <img src="https://dinaupcdn.com/logo.png" alt="Logo Dinaup" />
            </a>
        </p>
    }
    else
    {
        <div class="dnz-footer-powered__modern-row">
            <span class="dnz-footer-powered__modern-label">Powered by</span>
            <a href="https://dinaup.com"
               target="_blank"
               rel="noopener noreferrer"
               class="dnz-footer-powered__modern-link">
                <img src="https://dinaupcdn.com/logo.png" alt="Dinaup" />
            </a>
        </div>
    }
</footer>

@code {
    [Parameter]
    public FooterStyleType Style { get; set; } = FooterStyleType.Modern;

    private string GetFooterClass() => Style switch
    {
        FooterStyleType.Compact => "dnz-footer-powered",
        FooterStyleType.Modern => "dnz-footer-powered dnz-footer-powered--modern",
        _ => "dnz-footer-powered"
    };

    public enum FooterStyleType
    {
        Compact,
        Modern
    }
}

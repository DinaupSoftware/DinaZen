@namespace DinaZen.Components

<div class="@GetDnzBannerClass()">
	<div class="banner-content">
		@if (string.IsNullOrEmpty(Icon) == false)
		{
			<div class="banner-icon">
				<RadzenIcon Icon="@Icon" />
			</div>
		}
		<div class="banner-text">
			@if (string.IsNullOrEmpty(Title) == false)
			{
				<h3>@Title</h3>
			}
			@if (ChildContent != null)
			{
				@ChildContent
			}
		</div>
		@if (string.IsNullOrEmpty(ButtonText) == false && string.IsNullOrEmpty(DnzButtonrl) == false)
		{
			<a href="@DnzButtonrl" target="@(OpenInNewTab ? "_blank" : "_self")" class="banner-btn">
				<span>@ButtonText</span>
				<RadzenIcon Icon="arrow_forward" />
			</a>
		}
	</div>
</div>

@code {
	/// <summary>
	/// Icono Material Symbols (ej: "favorite", "update", "bolt")
	/// </summary>
	[Parameter] public string  Icon { get; set; } = string.Empty;

	/// <summary>
	/// Título principal del banner
	/// </summary>
	[Parameter] public string Title { get; set; } = string.Empty;

	/// <summary>
	/// Contenido HTML del banner (párrafos, strong, etc.)
	/// </summary>
	[Parameter] public RenderFragment  ChildContent { get; set; }

	/// <summary>
	/// Texto del botón de acción
	/// </summary>
	[Parameter] public string  ButtonText { get; set; } = string.Empty;

	/// <summary>
	/// URL de destino del botón
	/// </summary>
	[Parameter] public string  DnzButtonrl { get; set; } = string.Empty;

	/// <summary>
	/// Abrir enlace en nueva pestaña (default: true)
	/// </summary>
	[Parameter] public bool OpenInNewTab { get; set; } = true;

	/// <summary>
	/// Estilo visual del banner
	/// </summary>
	[Parameter] public DnzBannerStyle Style { get; set; } = DnzBannerStyle.Primary;

	/// <summary>
	/// Clases CSS adicionales
	/// </summary>
	[Parameter] public string  AdditionalClass { get; set; } = string.Empty;

	private string GetDnzBannerClass()
	{
		var styleClass = Style switch
		{
			// Principales
			DnzBannerStyle.Primary => "banner-primary",
			DnzBannerStyle.Gold => "banner-gold",
			DnzBannerStyle.Love => "banner-love",
			DnzBannerStyle.Danger => "banner-danger",
			DnzBannerStyle.Success => "banner-success",
			DnzBannerStyle.Warning => "banner-warning",
			// Badge-style
			DnzBannerStyle.Pro => "banner-pro",
			DnzBannerStyle.Beta => "banner-beta",
			DnzBannerStyle.New => "banner-new",
			DnzBannerStyle.Premium => "banner-premium",
			DnzBannerStyle.IA => "banner-ia",
			_ => "banner-primary"
		};

		return string.IsNullOrEmpty(AdditionalClass)
			? $"banner mb-4 mt-2 {styleClass}"
			: $"banner mb-4 mt-2 {styleClass} {AdditionalClass}";
	}

	/// <summary>
	/// Estilos visuales disponibles para el DnzBanner
	/// </summary>
	public enum DnzBannerStyle
	{
		// ═══════════════════════════════════════
		// PRINCIPALES
		// ═══════════════════════════════════════
		
		/// <summary>Azul Dinaup - Updates, versiones, destacados</summary>
		Primary,
		
		/// <summary>Dorado con destello - Premium, upgrade</summary>
		Gold,
		
		/// <summary>Rosa corazón - Amor, San Valentín, bodas</summary>
		Love,
		
		/// <summary>Rojo urgente - Crítico, últimas horas</summary>
		Danger,
		
		/// <summary>Verde éxito - Completado, verificado</summary>
		Success,
		
		/// <summary>Naranja aviso - Alertas graves, mantenimiento</summary>
		Warning,

		// ═══════════════════════════════════════
		// BADGE-STYLE
		// ═══════════════════════════════════════
		
		/// <summary>Violeta/Azul - Funcionalidades PRO</summary>
		Pro,
		
		/// <summary>Rojo/Naranja - Experimental, beta</summary>
		Beta,
		
		/// <summary>Cyan/Azul - Novedades, lanzamientos</summary>
		New,
		
		/// <summary>Dorado elegante - Ofertas premium</summary>
		Premium,
		
		/// <summary>Verde/Cyan - Inteligencia Artificial</summary>
		IA
	}
}

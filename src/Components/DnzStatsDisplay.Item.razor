<div class="text-center py-2 px-3">
    <div class="rz-text-display-h4 m-0 p-0">
        @Value

        @if (Unit.IsNotEmpty())
        {
            <span class="rz-text-display-h6 opacity-50 m-0 ms-2 p-0">@Unit</span>
        }
    </div>
    <div class="rz-text-subtitle1 m-0 p-0">
        @Label
    </div>
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Unit { get; set; } = "";
}

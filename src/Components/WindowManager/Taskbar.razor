@namespace DinaZen.Components.WindowManager
@implements IDisposable
@inject WindowManagerService WM

@if (WM.Windows.Any())
{
	<div class="dnz-taskbar">
		@foreach (var win in WM.Windows)
		{
			<TaskbarItem @key="win.Id"
							State="win"
							OnToggle="HandleToggle"
							OnClose="HandleClose" />
		}
	</div>
}

@code {
	protected override void OnInitialized()
	{
		WM.OnChanged += HandleStateChanged;
	}

	private void HandleToggle(string windowId)
	{
		WM.ToggleMinimize(windowId);
	}

	private void HandleClose(string windowId)
	{
		WM.Close(windowId);
	}

	private void HandleStateChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		WM.OnChanged -= HandleStateChanged;
	}
}

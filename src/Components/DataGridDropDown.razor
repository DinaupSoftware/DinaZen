@namespace DinaZen.Components
@using DemoUp.MyDinaup
@typeparam T where T : IDinaupRow

@if (TextProperty.IsEmpty())
{
	<RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" Size="AlertSize.ExtraSmall" Shade="Shade.Lighter" ShowIcon="false">
		<code>TextProperty</code> is required for <code>DataGridDropDown</code>.
	</RadzenAlert>
	return;
}

<RadzenFormField Visible=@Visible Text=@Label Variant="Variant.Flat" class=@(" dropdownup dropdown-menu-component" + ((IsRequired && Value.IsNull()) ? " obli" : "") + " " + (Disabled ? " dropdown-menu-component-disabled" : "") + " ") Style=@Style>
	<Start>
		@if (IconTemplate != null && Value.IsNotNull())
		{
			@IconTemplate(Value)
		}
		else if (Icon.IsNotEmpty())
		{
			<RadzenIcon Icon=@Icon />
		}
	</Start>
	<ChildContent>

		@if (Columns.IsNotNull() && ValueTemplate.IsNotNull())
		{
			<RadzenDropDownDataGrid FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" Disabled=@Disabled ShowSearch=@TextProperty.IsNotEmpty() TextProperty=@TextProperty ColumnWidth=@ColumnWidth ValueTemplate=@ValueTemplate @bind-Value=@Value Columns=@Columns TValue="T" Data=@Data Name="x" Style=@("cursor:pointer;flex:1;border:none;" + (_selectedId.IsNotEmpty() == false ? "color:#7F7F7F" : "")) />
		}
		else if (Columns.IsNotNull())
		{
			<RadzenDropDownDataGrid FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" Disabled=@Disabled ShowSearch=@TextProperty.IsNotEmpty() TextProperty=@TextProperty ColumnWidth=@ColumnWidth Columns=@Columns @bind-Value=@Value TValue="T" Data=@Data Name="x" Style=@("cursor:pointer;flex:1;border:none;" + (_selectedId.IsNotEmpty() == false ? "color:#7F7F7F" : "")) />
		}
		else if (ValueTemplate.IsNotNull())
		{
			<RadzenDropDownDataGrid FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" Disabled=@Disabled ShowSearch=@TextProperty.IsNotEmpty() TextProperty=@TextProperty ColumnWidth=@ColumnWidth ValueTemplate=@ValueTemplate @bind-Value=@Value TValue="T" Data=@Data Name="x" Style=@("cursor:pointer;flex:1;border:none;" + (_selectedId.IsNotEmpty() == false ? "color:#7F7F7F" : "")) />
		}
		else
		{
			<RadzenDropDownDataGrid Disabled=@Disabled FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" PageSize="10" ShowSearch=@TextProperty.IsNotEmpty() TextProperty=@TextProperty ColumnWidth=@ColumnWidth @bind-Value=@Value
									TValue="T" Data=@Data Name="x" Style=@("cursor:pointer;flex:1;border:none;" + (_selectedId.IsNotEmpty() == false ? "color:#7F7F7F" : ""))>
				<Columns>
					<RadzenDropDownDataGridColumn Title=@Label Width="100px">
						<Template>
							<div class="d-flex gap-1 align-content-center align-items-center">
								@if (IconTemplate != null)
								{
									@IconTemplate((T)context)
								}
								@if (_hasColorProperty == false)
								{
									@((context as IDinaupRow).Label)
								}
								else
								{
									<BadgetAutoColor Color="@ResolveColor(context)" Value=@((context as IDinaupRow).Label) />
								}
							</div>
						</Template>
					</RadzenDropDownDataGridColumn>
				</Columns>
				<ValueTemplate>
					<div class="d-flex gap-1 align-content-center align-items-center">
						@if (_hasColorProperty == false)
						{
							@((context as IDinaupRow).Label)
						}
						else
						{
							<BadgetAutoColor Color="@ResolveColor(context)" Value=@((context as IDinaupRow).Label) />
						}
					</div>
				</ValueTemplate>
			</RadzenDropDownDataGrid>
		}

	</ChildContent>
	<End>
		@if (Disabled)
		{
		}
		else if (Value != null)
		{
			<div class="d-flex flex-column gap-1 align-items-end justify-content-center h-100">
				<RadzenIcon Icon="close" IconColor="#8D0909" Style="font-size:13px; cursor: pointer" onclick=@(() => HandleRemoveClick()) />
				@if (OnOpen.HasDelegate)
				{
					<RadzenIcon Icon="open_in_new" IconColor="#002C92" Style="font-size:13px; cursor: pointer" onclick=@(() => HandleOpenClick()) />
				}
			</div>
		}
		else
		{
			@if (OnAdd.HasDelegate)
			{
				<RadzenButton Icon="add" Style="font-size:13px;" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" Click=@HandleAddClick />
			}
		}
	</End>
</RadzenFormField>

@code {

	// ── Display ──

	[Parameter] public string Icon { get; set; }
	[Parameter] public string Label { get; set; }
	[Parameter] public string Style { get; set; }
	[Parameter] public bool Visible { get; set; } = true;

	// ── Behavior ──

	[Parameter] public bool IsRequired { get; set; }
	[Parameter] public bool Disabled { get; set; }

	// ── Data ──

	[Parameter] public string TextProperty { get; set; }
	[Parameter] public string ColorProperty { get; set; }
	[Parameter] public string IconoProperty { get; set; }
	[Parameter] public IEnumerable<T> Data { get; set; } = new List<T>();

	// ── Templates ──

	[Parameter] public RenderFragment Columns { get; set; }
	[Parameter] public RenderFragment<dynamic> ValueTemplate { get; set; }
	[Parameter] public RenderFragment<T> IconTemplate { get; set; }
	[Parameter] public string ColumnWidth { get; set; } = "";

	// ── Events ──

	[Parameter] public EventCallback<T> ValueChanged { get; set; }
	[Parameter] public EventCallback OnAdd { get; set; }
	[Parameter] public EventCallback<T> OnRemove { get; set; }
	[Parameter] public EventCallback<T> OnOpen { get; set; }

	// ── Selection ──

	private Guid _selectedId;
	private bool _hasColorProperty;
	private System.Reflection.PropertyInfo _colorPropertyInfo;

	private T _value;
	[Parameter]
	public T Value
	{
		get => _value;
		set
		{
			if (EqualityComparer<T>.Default.Equals(_value, value) == false)
			{
				_value = value;

				if (value.IsNull())
					_selectedId = Guid.Empty;
				else if (value.Id != _selectedId)
					_selectedId = value.Id;

				if (ValueChanged.HasDelegate)
					ValueChanged.InvokeAsync(value);
			}
		}
	}

	// ── Lifecycle ──

	protected override async Task OnParametersSetAsync()
	{
		await base.OnParametersSetAsync();

		try
		{
			_colorPropertyInfo = ColorProperty.IsNotEmpty()
				? typeof(T).GetProperty(ColorProperty)
				: null;
		}
		catch (Exception)
		{
			_colorPropertyInfo = null;
		}

		_hasColorProperty = ColorProperty.IsNotEmpty() && _colorPropertyInfo.IsNotNull();
	}

	// ── Helpers ──

	private EnumTextoEstiloE ResolveColor(dynamic context)
	{
		try
		{
			if (ColorProperty.IsNotEmpty() && _colorPropertyInfo.IsNotNull())
			{
				var raw = _colorPropertyInfo.GetValue(context, null) as string;
				if (raw.IsNotNull() && Enum.TryParse(typeof(EnumTextoEstiloE), raw, out var parsed))
					return (EnumTextoEstiloE)parsed;
			}
		}
		catch (Exception)
		{
		}
		return EnumTextoEstiloE.Indefinido;
	}

	// ── Event Handlers ──

	private async Task HandleAddClick()
	{
		if (OnAdd.HasDelegate)
			await OnAdd.InvokeAsync(Value);
	}

	private async Task HandleRemoveClick()
	{
		if (OnRemove.HasDelegate)
			await OnRemove.InvokeAsync(Value);
		else
			Value = default(T);
	}

	private async Task HandleOpenClick()
	{
		if (OnOpen.HasDelegate)
			await OnOpen.InvokeAsync(Value);
	}
}

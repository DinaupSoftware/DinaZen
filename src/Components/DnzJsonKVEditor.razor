@using System.Text.Json
@using System.Text
@inject TooltipService TooltipService

<div class="dz-jsonkv-editor @Class" style="@Style">
    <div class="dz-jsonkv-toolbar">
        <span class="dz-jsonkv-title">
            <RadzenIcon Icon="data_object" Style="font-size: 16px;" />
            Key / Value Editor
        </span>
        <div class="d-flex align-items-center gap-1">
            <RadzenButton Text="Copy" Icon="content_copy" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Click="OnCopy" />
            @if (showPasteArea == false)
            {
                <RadzenButton Text="Paste" Icon="content_paste" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Click="ShowPaste" />
            }
            <RadzenButton Icon="add" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Primary" Click="AddEntry" MouseEnter="@(args => TooltipService.Open(args, "Add entry"))" />
        </div>
    </div>

    @if (showPasteArea)
    {
        <div class="dz-jsonkv-paste">
            <textarea @ref="pasteTextArea" class="dz-jsonkv-paste-input" rows="5"
                      placeholder="Paste JSON here (Ctrl+V)..."
                      @bind="pasteText" @bind:event="oninput"></textarea>
            <div class="dz-jsonkv-paste-actions">
                <RadzenButton Text="Import" Icon="check" Size="ButtonSize.ExtraSmall"
                              ButtonStyle="ButtonStyle.Primary" Click="ApplyPaste" />
                <RadzenButton Text="Cancel" Icon="close" Size="ButtonSize.ExtraSmall"
                              Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Click="CancelPaste" />
            </div>
        </div>
    }
    else
    {
        <div class="dz-jsonkv-info">
            <RadzenIcon Icon="info" Style="font-size: 13px;" />
            Use dot notation for grouping: <code>app.apikey</code>, <code>app.secret</code>
        </div>

        @if (entries.Count == 0)
        {
            <div class="dz-jsonkv-empty" @onclick="AddEntry">
                <RadzenIcon Icon="add_circle_outline" Style="font-size: 24px; opacity: 0.4;" />
                <span>No entries. Click to add one.</span>
            </div>
        }
        else
        {
            <div class="dz-jsonkv-rows">
                @for (int i = 0; i < entries.Count; i++)
                {
                    var index = i;
                    var entry = entries[index];
                    <div class="dz-jsonkv-row">
                        <input type="text" class="dz-jsonkv-key" placeholder="key"
                               value="@entry.Key"
                               @onchange="(e => OnKeyChanged(index, e))" />
                        <input type="text" class="dz-jsonkv-value" placeholder="value"
                               value="@entry.Value"
                               @onchange="(e => OnValueChanged(index, e))" />
                        <button class="dz-jsonkv-remove" @onclick="(() => RemoveEntry(index))"
                                title="Remove">
                            <RadzenIcon Icon="close" Style="font-size: 14px;" />
                        </button>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "{}";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string Style { get; set; } = "";
    [Parameter] public bool ReadOnly { get; set; } = false;

    private List<KVEntry> entries = new();
    private string lastParsedJson = "";
    private bool showPasteArea;
    private string pasteText = "";
    private ElementReference pasteTextArea;

    protected override void OnParametersSet()
    {
        var json = Value ?? "{}";
        if (json != lastParsedJson)
        {
            ParseJson(json);
            lastParsedJson = json;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showPasteArea)
        {
            try { await pasteTextArea.FocusAsync(); } catch { }
        }
    }

    private void ParseJson(string json)
    {
        entries.Clear();
        try
        {
            if (string.IsNullOrWhiteSpace(json)) return;
            var doc = JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind == JsonValueKind.Object)
            {
                foreach (var prop in doc.RootElement.EnumerateObject())
                {
                    entries.Add(new KVEntry
                    {
                        Key = prop.Name,
                        Value = prop.Value.ValueKind == JsonValueKind.String
                            ? prop.Value.GetString() ?? ""
                            : prop.Value.GetRawText()
                    });
                }
            }
        }
        catch
        {
            // If JSON is invalid, start empty
        }
    }

    private string BuildJson()
    {
        var dict = new Dictionary<string, string>();
        foreach (var e in entries)
        {
            var key = (e.Key ?? "").Trim();
            if (string.IsNullOrEmpty(key) == false && dict.ContainsKey(key) == false)
            {
                dict[key] = e.Value ?? "";
            }
        }
        return JsonSerializer.Serialize(dict, new JsonSerializerOptions { WriteIndented = true });
    }

    private async Task NotifyChanged()
    {
        var json = BuildJson();
        lastParsedJson = json;
        await ValueChanged.InvokeAsync(json);
    }

    private async Task OnKeyChanged(int index, ChangeEventArgs e)
    {
        if (ReadOnly) return;
        entries[index].Key = e.Value?.ToString() ?? "";
        await NotifyChanged();
    }

    private async Task OnValueChanged(int index, ChangeEventArgs e)
    {
        if (ReadOnly) return;
        entries[index].Value = e.Value?.ToString() ?? "";
        await NotifyChanged();
    }

    private async Task AddEntry()
    {
        if (ReadOnly) return;
        entries.Add(new KVEntry());
        await NotifyChanged();
    }

    private async Task RemoveEntry(int index)
    {
        if (ReadOnly) return;
        entries.RemoveAt(index);
        await NotifyChanged();
    }

    private async Task OnCopy()
    {
        var json = BuildJson();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
        NotificationService.Notify(NotificationSeverity.Success, "Copied", "JSON copied to clipboard");
    }

    private void ShowPaste()
    {
        if (ReadOnly) return;
        pasteText = "";
        showPasteArea = true;
    }

    private void CancelPaste()
    {
        showPasteArea = false;
        pasteText = "";
    }

    private async Task ApplyPaste()
    {
        if (string.IsNullOrWhiteSpace(pasteText))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Empty", "Paste some JSON first");
            return;
        }

        try
        {
            var text = pasteText.Replace('\u201C', '"').Replace('\u201D', '"')
                                .Replace('\u2018', '\'').Replace('\u2019', '\'');

            var doc = JsonDocument.Parse(text);
            if (doc.RootElement.ValueKind != JsonValueKind.Object)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Invalid JSON", "Expected a JSON object with key-value pairs");
                return;
            }

            entries.Clear();
            var count = 0;
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                entries.Add(new KVEntry
                {
                    Key = prop.Name,
                    Value = prop.Value.ValueKind == JsonValueKind.String
                        ? prop.Value.GetString() ?? ""
                        : prop.Value.GetRawText()
                });
                count++;
            }
            showPasteArea = false;
            pasteText = "";
            await NotifyChanged();
            NotificationService.Notify(NotificationSeverity.Success, "Pasted", $"{count} entries loaded");
        }
        catch (JsonException)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Invalid JSON", "Text is not valid JSON");
        }
    }

    private class KVEntry
    {
        public string Key { get; set; } = "";
        public string Value { get; set; } = "";
    }
}

@using DinaZen.Components
@inject TooltipService TooltipService
<DialogLayout>
	<TitleContent>
		<div class="d-flex align-items-center justify-content-between w-100">
			<div class="d-flex align-items-center gap-2">
				<RadzenIcon Icon="history" Style="color:var(--rz-primary); font-size:20px" />
				<span style="font-weight:600">Historial de cambios</span>
				@if (cargando == false && HistoryList.IsNotEmpty())
				{
					<RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@($"{HistoryList.Count}")" Style="font-size:11px" />
				}
			</div>
			<div class="d-flex align-items-center gap-1">
				@if (cargando == false && HistoryList.IsNotEmpty())
				{
					<RadzenButton Icon="@(isCompact ? "unfold_more" : "unfold_less")"
								  ButtonStyle="ButtonStyle.Light"
								  Variant="Variant.Text"
								  Size="ButtonSize.Small"
								  Click="@(() => { isCompact = (isCompact == false); })"
								  MouseEnter="@(args => TooltipService.Open(args, isCompact ? "Vista expandida" : "Vista compacta", null))"
								  MouseLeave="@(args => TooltipService.Close())" />
				}
				<RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
							  Click="@(() => DialogService.Close())" Style="opacity:0.6" />
			</div>
		</div>
	</TitleContent>
	<BodyContent>

		@if (cargando)
		{
			<div class="dnz-history-skeleton">
				@for (int i = 0; i < 5; i++)
				{
					<div class="dnz-history-skeleton-item">
						<div class="dnz-history-skeleton-dot"></div>
						<div class="dnz-history-skeleton-content">
							<Skeleton Lines="1" Height="0.7rem" MaxWidth="55%" />
							<Skeleton Lines="2" Height="0.9rem" MaxWidth="100%" />
						</div>
					</div>
				}
			</div>
		}
		else if (HistoryList.IsNotEmpty())
		{
			<div class="dnz-history-timeline">
				@{ string lastGroup = null; }
				@foreach (var item in HistoryList.OrderByDescending(x => x.EditedOn))
				{
					var group = GetDateGroupLabel(item.EditedOn);
					@if (group != lastGroup)
					{
						lastGroup = group;
						<div class="dnz-history-date-group">
							<span class="dnz-history-date-label">@group</span>
							<div class="dnz-history-date-line"></div>
						</div>
					}

					var oldVal = item.OldValueText.IfIsEmpty(item.OldValue);
					var newVal = item.NewValueText.IfIsEmpty(item.NewValue);

					<div class="dnz-history-entry @(isCompact ? "compact" : "")">
						<div class="dnz-history-rail">
							<div class="dnz-history-dot"></div>
							<div class="dnz-history-connector"></div>
						</div>

						<div class="dnz-history-content">
							<div class="dnz-history-meta">
								<AvatarInitial Data="@item.EditedByUserName" Size="1.4rem" Style="font-size:0.65rem" />
								<span class="dnz-history-author">@item.EditedByUserName</span>
								<SpanDateTime Value="@item.EditedOn" Caption="true" FontSize="11px" />
							</div>

							@if (isCompact == false)
							{
								<div class="dnz-history-diff">
									@if (oldVal.IsNotEmpty())
									{
										<div class="dnz-history-diff-removed">
											<RadzenIcon Icon="remove" Style="font-size:12px" />
											<span>@oldVal</span>
										</div>
									}
									else
									{
										<div class="dnz-history-diff-empty">
											<span class="rz-text-caption">(vacío)</span>
										</div>
									}
									<div class="dnz-history-diff-added">
										<RadzenIcon Icon="add" Style="font-size:12px" />
										<span>@newVal</span>
									</div>
								</div>
							}
							else
							{
								<div class="dnz-history-compact-diff">
									@if (oldVal.IsNotEmpty())
									{
										<span class="dnz-history-compact-old" title="@oldVal">@Truncar(oldVal, 35)</span>
										<RadzenIcon Icon="arrow_forward" Style="font-size:11px; opacity:0.4; margin:0 2px" />
									}
									<span class="dnz-history-compact-new" title="@newVal">@Truncar(newVal, 35)</span>
								</div>
							}
						</div>
					</div>
				}
			</div>
		}
		else
		{
			<div class="dnz-history-empty">
				<RadzenIcon Icon="history_toggle_off" Style="font-size:48px; opacity:0.2" />
				<span style="color:#999; font-size:13px; margin-top:6px">No se han registrado cambios.</span>
			</div>
		}

	</BodyContent>
</DialogLayout>


@code {

	public static async Task Open(DialogService dialogService, DinaupClientC client, Guid sectionId, Guid rowId, string field)
	{
		var parameters = new Dictionary<string, object>()
		{
			{ nameof(Client), client },
			{ nameof(SectionId), sectionId },
			{ nameof(Id), rowId },
			{ nameof(Field), field }
		};
		var options = new DialogOptions()
		{
			Width = "560px",
			Height = "70%",
			ShowClose = false,
			ShowTitle = false,
			Resizable = true,
			Draggable = true,
			CloseDialogOnOverlayClick = true,
			CloseDialogOnEsc = true
		};

		await dialogService.OpenAsync<HistoricoDialog>("Historial", parameters, options);
	}


	[Parameter] public DinaupClientC Client { get; set; }
	[Parameter] public Guid Id { get; set; }
	[Parameter] public Guid SectionId { get; set; }
	[Parameter] public string Field { get; set; }

	private List<DinaupFieldChangeDTO> HistoryList { get; set; } = new();
	private bool cargando = true;
	private bool isCompact = false;

	protected async override Task OnInitializedAsync()
	{
		await base.OnInitializedAsync();
		HistoryList = await Client.GetHistoryChanges(SectionId, Id, Field);
		cargando = false;
	}

	private string GetDateGroupLabel(DateTime date)
	{
		var today = DateTime.Today;
		if (date.Date == today) return "Hoy";
		if (date.Date == today.AddDays(-1)) return "Ayer";
		if (date.Date >= today.AddDays(-7)) return "Esta semana";
		if (date.Date.Month == today.Month && date.Date.Year == today.Year) return "Este mes";
		return date.ToString("MMMM yyyy");
	}

	private static string Truncar(string value, int max)
	{
		if (string.IsNullOrEmpty(value)) return "";
		return value.Length > max ? value[..max] + "..." : value;
	}
}

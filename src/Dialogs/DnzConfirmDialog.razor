<div class="dnz-confirm-root d-flex flex-column">
	<div class="d-flex align-items-center gap-2 px-3 py-2" style="border-bottom:1px solid var(--rz-border-color, #e0e0e0); flex-shrink:0;">
		<RadzenIcon Icon=@_headerIcon Style=@($"color:{_accentColor}; font-size:20px") />
		<span style="font-weight:600; font-size:0.95em; flex:1; min-width:0;">@Title</span>
		<RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => DialogService.Close(false))" Style="opacity:0.6; flex-shrink:0;" />
	</div>
	<div class="d-flex flex-column align-items-center gap-3 py-4 px-4" style="text-align:center; flex:1; min-height:0; overflow-y:auto;">
		<div class="d-flex align-items-center justify-content-center" style="width:56px; height:56px; border-radius:50%; background:@_accentBg; flex-shrink:0;">
			<RadzenIcon Icon=@_bodyIcon Style=@($"font-size:28px; color:{_accentColor};") />
		</div>
		<span style="font-size:0.95em; color:var(--rz-text-color); line-height:1.55;">@Message</span>
	</div>
	<div class="d-flex justify-content-end gap-2 align-items-center px-3 py-2" style="border-top:1px solid var(--rz-border-color, #e0e0e0); flex-shrink:0;">
		<RadzenButton Click="@(() => DialogService.Close(false))" ButtonStyle="ButtonStyle.Secondary" Text=@CancelText Variant="Variant.Text" Style="opacity:0.8" />
		<RadzenButton Click="@(() => DialogService.Close(true))" ButtonStyle=@_okButtonStyle Text=@OkText Icon=@_headerIcon Variant="Variant.Flat" />
	</div>
</div>

@code {
	[Parameter] public string Title { get; set; } = "Confirmar";
	[Parameter] public string Message { get; set; } = "";
	[Parameter] public string OkText { get; set; } = "Confirmar";
	[Parameter] public string CancelText { get; set; } = "Cancelar";
	[Parameter] public DnzConfirmSeverity Severity { get; set; } = DnzConfirmSeverity.Warning;

	private string _headerIcon => Severity switch {
		DnzConfirmSeverity.Danger => "warning",
		DnzConfirmSeverity.Warning => "error_outline",
		DnzConfirmSeverity.Info => "info",
		DnzConfirmSeverity.Success => "check_circle",
		_ => "help_outline"
	};

	private string _bodyIcon => _headerIcon;

	private string _accentColor => Severity switch {
		DnzConfirmSeverity.Danger => "var(--rz-danger)",
		DnzConfirmSeverity.Warning => "var(--rz-warning)",
		DnzConfirmSeverity.Info => "var(--rz-info)",
		DnzConfirmSeverity.Success => "var(--rz-success)",
		_ => "var(--rz-info)"
	};

	private string _accentBg => Severity switch {
		DnzConfirmSeverity.Danger => "var(--rz-danger-lighter)",
		DnzConfirmSeverity.Warning => "var(--rz-warning-lighter)",
		DnzConfirmSeverity.Info => "var(--rz-info-lighter)",
		DnzConfirmSeverity.Success => "var(--rz-success-lighter)",
		_ => "var(--rz-info-lighter)"
	};

	private ButtonStyle _okButtonStyle => Severity switch {
		DnzConfirmSeverity.Danger => ButtonStyle.Danger,
		DnzConfirmSeverity.Warning => ButtonStyle.Warning,
		DnzConfirmSeverity.Info => ButtonStyle.Info,
		DnzConfirmSeverity.Success => ButtonStyle.Success,
		_ => ButtonStyle.Primary
	};

	/// <summary>
	/// Opens a styled confirmation dialog. Returns true if confirmed, false otherwise.
	/// </summary>
	public static async Task<bool> OpenAsync(DialogService dialogService, string message, string title = "Confirmar", DnzConfirmSeverity severity = DnzConfirmSeverity.Warning, string okText = "Confirmar", string cancelText = "Cancelar") {
		var parameters = new Dictionary<string, object>()
		{
			{ nameof(Title), title },
			{ nameof(Message), message },
			{ nameof(OkText), okText },
			{ nameof(CancelText), cancelText },
			{ nameof(Severity), severity },
		};
		var options = new DialogOptions() {
			Width = "min(520px, 92vw)",
			Height = "auto",
			ShowClose = false,
			ShowTitle = false,
			CloseDialogOnOverlayClick = true,
			CloseDialogOnEsc = true,
			CssClass = "dnz-confirm-dialog"
		};

		var result = await dialogService.OpenAsync<DnzConfirmDialog>("Confirm", parameters, options);
		return result is true;
	}
}
 